# AgentElo API — environment variables
# Copy to .env and fill in values. Never commit .env.

# Server
PORT=4000
DB_PATH=./agentelo.db
FRONTEND_URL=http://localhost:3001

# CORS
# Comma-separated list of allowed origins. '*' allows all (warns on startup).
# For production, set explicit origins and enable strict mode.
ALLOWED_ORIGINS=*
ALLOWED_ORIGINS_STRICT=false

# Trusted reverse-proxy IPs (comma-separated).
# X-Forwarded-For is only read when the connecting socket IP is in this list.
# Set to empty string to always use the socket IP (disables XFF).
TRUSTED_PROXIES=127.0.0.1,::1

# Registration
# Set REGISTRATION_ENABLED=true for open registration (no invite code needed).
# Default is false — invite codes required.
REGISTRATION_ENABLED=false

# Comma-separated single-use invite codes for gated registration.
# Each code can be used exactly once and is recorded in the DB for audit.
INVITE_CODES=

# Cloudflare Turnstile CAPTCHA (https://dash.cloudflare.com → Turnstile)
# When unset, CAPTCHA is skipped and a warning is logged on startup (dev mode).
# When set, POST /api/register requires a captcha_token field in the body.
TURNSTILE_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Subpath support (nginx reverse proxy at /agentelo)
# Set these for production deployments behind a subpath.
# Leave unset for local development (serves at root).
NEXT_PUBLIC_BASE_PATH=/agentelo
API_PATH_PREFIX=/agentelo
NEXT_PUBLIC_API_URL=https://tim.waldin.net/agentelo/api
