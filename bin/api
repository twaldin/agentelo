#!/usr/bin/env node
'use strict';

const http   = require('http');
const fs     = require('fs');
const path   = require('path');
const crypto = require('crypto');
const db     = require('../core/db');
const { updateRating, defaultRating } = require('../core/glicko2');

const PORT       = process.env.PORT || 4000;
const PUBLIC_DIR = path.join(__dirname, '..', 'public');

// ── helpers ───────────────────────────────────────────────────────────────────

function json(res, status, data) {
  const body = JSON.stringify(data);
  res.writeHead(status, {
    'Content-Type': 'application/json',
    'Access-Control-Allow-Origin': '*',
    'Content-Length': Buffer.byteLength(body),
  });
  res.end(body);
}

function readBody(req) {
  return new Promise((resolve, reject) => {
    let data = '';
    req.on('data', chunk => { data += chunk; });
    req.on('end', () => {
      try { resolve(JSON.parse(data)); }
      catch (e) { reject(e); }
    });
    req.on('error', reject);
  });
}

function diffLabel(row) {
  const lines = row.difficulty_lines || 0;
  if (lines <= 20)  return 'easy';
  if (lines <= 80)  return 'medium';
  if (lines <= 200) return 'hard';
  return 'expert';
}

function fmtTime(secs) {
  if (!secs) return '—';
  const m = Math.floor(secs / 60);
  const s = Math.round(secs % 60);
  return m > 0 ? `${m}m ${s}s` : `${s}s`;
}

function detectLang(repo) {
  if (!repo) return 'unknown';
  const r = repo.toLowerCase();
  if (r.includes('django') || r.includes('flask') || r.includes('fastapi') || r.includes('python')) return 'python';
  if (r.includes('angular') || r.includes('react') || r.includes('next') || r.includes('vue') || r.includes('svelte')) return 'typescript';
  if (r.includes('golang') || r.includes('/go') || r.includes('tokio') || r.includes('rust')) return 'rust';
  return 'javascript';
}

function buildChallengeEntry(row, stats) {
  const s = stats || { total: 0, wins: 0, avg_time: 0, avg_agent_time: 0 };
  return {
    id:           row.id,
    repo:         (row.repo || '').replace('https://github.com/', ''),
    title:        row.title || row.id,
    diff:         diffLabel(row),
    lang:         detectLang(row.repo),
    sr:           s.total > 0 ? s.wins / s.total : 0,
    att:          s.total || 0,
    avgt:         fmtTime(s.avg_agent_time || s.avg_time),
    test_command: row.test_command,
    created_at:   row.created_at,
  };
}

function buildAgentEntry(agent, rank, allAgents) {
  const history  = db.getRatingHistory(agent.id);
  const hist     = history.slice(-10).map(h => Math.round(h.rating_after));

  // d7: sum of deltas from games in last 7 days
  const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
  const d7 = history
    .filter(h => h.created_at >= sevenDaysAgo)
    .reduce((sum, h) => sum + (h.delta || 0), 0);

  const subs   = db.getSubmissionsByAgent(agent.id).slice(0, 3);
  const recent = subs.map(s => {
    const ch = db.getChallenge(s.challenge_id);
    return {
      n:  ch ? ch.repo.replace('https://github.com/', '').split('/')[1] + '/' + s.challenge_id : s.challenge_id,
      st: s.tests_passed ? 'pass' : 'fail',
      sc: s.tests_passed ? '✓' : '✗',
      t:  fmtTime(s.agent_time_seconds),
    };
  });

  const played = agent.challenges_attempted || 0;

  return {
    id:      agent.id,
    rank,
    name:    agent.id,
    harness: agent.harness,
    model:   agent.model,
    elo:     Math.round(agent.rating),
    rd:      Math.round(agent.rd),
    wr:      played > 0 ? agent.wins / played : 0,
    played,
    wins:    agent.wins || 0,
    d7:      Math.round(d7),
    hist,
    hash:    agent.current_hash ? agent.current_hash.slice(0, 8) : null,
    recent,
  };
}

// ── processSubmission ─────────────────────────────────────────────────────────

async function processSubmission(body) {
  // 1. Authenticate via api_key
  if (!body.api_key) throw Object.assign(new Error('Missing api_key'), { status: 401 });
  const agent = db.getAgentByKey(body.api_key);
  if (!agent) throw Object.assign(new Error('Invalid API key'), { status: 401 });

  // 2. Track config version changes
  if (agent.current_hash !== body.agent_hash) {
    db.insertConfigVersion({
      agent_id:     agent.id,
      agent_hash:   body.agent_hash,
      harness:      body.harness || agent.harness,
      model:        body.model   || agent.model,
      config_files: body.config_files || [],
    });
  }

  // 3. Upsert challenge
  const challengeFile = path.join(__dirname, '..', 'challenges', `${body.challenge_id}.json`);
  let challengeMeta = null;
  try { challengeMeta = JSON.parse(fs.readFileSync(challengeFile, 'utf8')); } catch (_) {}

  const existing = db.getChallenge(body.challenge_id);
  if (!existing || !existing.repo) {
    const repo     = body.repo || (challengeMeta && (challengeMeta.repoUrl || challengeMeta.repo)) || '';
    const title    = (challengeMeta && challengeMeta.issue && challengeMeta.issue.title) || body.challenge_id;
    const fixDiff  = (challengeMeta && challengeMeta.fixDiff) || '';
    const diffLines = fixDiff.split('\n').filter(l => /^[+-]/.test(l) && !/^[+-]{3}/.test(l)).length;
    db.upsertChallenge({
      id:          body.challenge_id,
      repo,
      title,
      difficulty:  { filesChanged: 0, linesAdded: diffLines },
      testCommand: challengeMeta && challengeMeta.testCommand,
      fixCommit:   challengeMeta && challengeMeta.fixCommit,
    });
  }

  // 4. Insert submission
  db.insertSubmission({
    run_id:             body.run_id,
    challenge_id:       body.challenge_id,
    agent_id:           agent.id,
    agent_hash:         body.agent_hash || '',
    harness:            body.harness    || agent.harness,
    model:              body.model      || agent.model,
    tests_passed:       body.tests_passed ? 1 : 0,
    tests_total:        body.tests_total  || 0,
    tests_ok:           body.tests_ok     || 0,
    tests_failed:       body.tests_failed || 0,
    agent_time_seconds: body.agent_time_seconds || 0,
    test_time_seconds:  body.test_time_seconds  || 0,
    diff_lines:         body.diff_lines  || 0,
    diff:               body.diff        || '',
    exit_code:          body.exit_code  != null ? body.exit_code : 1,
    tampered:           body.tampered   ? 1 : 0,
    transcript_path:    body.log_file   || null,
    created_at:         body.finished_at || new Date().toISOString(),
  });

  // 5. Get inserted submission's integer id
  const mySub = db.getSubmission(body.run_id);
  if (!mySub) throw new Error('Failed to retrieve inserted submission');

  // 6. Find opponent submissions for same challenge
  const opponents = db.getSubmissionsByChallenge(body.challenge_id)
    .filter(s => s.run_id !== body.run_id && s.agent_id !== agent.id);

  if (opponents.length === 0) {
    // No opponents — just increment challenges_attempted and update hash
    db.updateAgent({
      id:                   agent.id,
      rating:               agent.rating,
      rd:                   agent.rd,
      volatility:           agent.volatility,
      wins:                 agent.wins,
      challenges_attempted: agent.challenges_attempted + 1,
      current_hash:         body.agent_hash,
    });
    return;
  }

  // 7. Build games array for Glicko-2 batch update
  const games           = [];
  const opponentUpdates = [];

  for (const oSub of opponents) {
    const oppAgent = db.getAgent(oSub.agent_id);
    if (!oppAgent) continue;

    let myScore;
    const myPassed  = body.tests_passed ? 1 : 0;
    const oppPassed = oSub.tests_passed ? 1 : 0;

    if (myPassed > oppPassed) {
      myScore = 1;
    } else if (myPassed < oppPassed) {
      myScore = 0;
    } else if (myPassed === 1) {
      // Both passed — faster wins
      if ((body.agent_time_seconds || 0) < (oSub.agent_time_seconds || 0))      myScore = 1;
      else if ((body.agent_time_seconds || 0) > (oSub.agent_time_seconds || 0)) myScore = 0;
      else                                                                        myScore = 0.5;
    } else {
      // Both failed — more tests passing = win
      const myOk  = body.tests_ok || 0;
      const oppOk = oSub.tests_ok || 0;
      if (myOk > oppOk)      myScore = 1;
      else if (myOk < oppOk) myScore = 0;
      else                   myScore = 0.5;
    }

    games.push({ opponentRating: oppAgent.rating, opponentRd: oppAgent.rd, score: myScore });
    opponentUpdates.push({ oppAgent, oSub, myScore });
  }

  // 8. Batch Glicko-2 update for submitting agent
  const myNew  = updateRating(
    { rating: agent.rating, rd: agent.rd, volatility: agent.volatility },
    games
  );
  const myWins     = games.filter(g => g.score === 1).length;
  const myDeltaTotal = myNew.rating - agent.rating;

  // 9. Insert game rows and update opponent ratings
  for (let i = 0; i < opponentUpdates.length; i++) {
    const { oppAgent, oSub, myScore } = opponentUpdates[i];
    const oppScore = myScore === 1 ? 0 : myScore === 0 ? 1 : 0.5;

    // Per-game delta for submitting agent: prorate total delta evenly across opponents
    const perGameDelta = Math.round((myDeltaTotal / opponentUpdates.length) * 10) / 10;
    const myRatingAfterGame = Math.round((agent.rating + perGameDelta) * 10) / 10;

    // Insert game row for submitting agent
    db.insertGame({
      challenge_id:          body.challenge_id,
      agent_id:              agent.id,
      opponent_id:           oppAgent.id,
      submission_id:         mySub.id,
      opponent_submission_id: oSub.id,
      score:                 myScore,
      rating_before:         agent.rating,
      rating_after:          myRatingAfterGame,
      rd_before:             agent.rd,
      rd_after:              myNew.rd,
      delta:                 perGameDelta,
      opponent_rating:       oppAgent.rating,
      opponent_rd:           oppAgent.rd,
      opponent_model:        oppAgent.model,
    });

    // Compute opponent's new rating
    const oppNew = updateRating(
      { rating: oppAgent.rating, rd: oppAgent.rd, volatility: oppAgent.volatility },
      [{ opponentRating: agent.rating, opponentRd: agent.rd, score: oppScore }]
    );
    const oppDelta = oppNew.rating - oppAgent.rating;

    // Insert game row for opponent
    db.insertGame({
      challenge_id:          body.challenge_id,
      agent_id:              oppAgent.id,
      opponent_id:           agent.id,
      submission_id:         oSub.id,
      opponent_submission_id: mySub.id,
      score:                 oppScore,
      rating_before:         oppAgent.rating,
      rating_after:          oppNew.rating,
      rd_before:             oppAgent.rd,
      rd_after:              oppNew.rd,
      delta:                 oppDelta,
      opponent_rating:       agent.rating,
      opponent_rd:           agent.rd,
      opponent_model:        agent.model,
    });

    // Update opponent agent
    db.updateAgent({
      id:                   oppAgent.id,
      rating:               oppNew.rating,
      rd:                   oppNew.rd,
      volatility:           oppNew.volatility,
      wins:                 oppScore === 1 ? oppAgent.wins + 1 : oppAgent.wins,
      challenges_attempted: oppAgent.challenges_attempted,
      current_hash:         oppAgent.current_hash,
    });
  }

  // 10. Update submitting agent
  db.updateAgent({
    id:                   agent.id,
    rating:               myNew.rating,
    rd:                   myNew.rd,
    volatility:           myNew.volatility,
    wins:                 agent.wins + myWins,
    challenges_attempted: agent.challenges_attempted + 1,
    current_hash:         body.agent_hash,
  });
}

// ── router ────────────────────────────────────────────────────────────────────

async function handleRequest(req, res) {
  const url      = new URL(req.url, `http://localhost:${PORT}`);
  const pathname = url.pathname;

  if (req.method === 'OPTIONS') {
    res.writeHead(204, {
      'Access-Control-Allow-Origin':  '*',
      'Access-Control-Allow-Methods': 'GET,POST',
      'Access-Control-Allow-Headers': 'Content-Type',
    });
    return res.end();
  }

  // Frontend
  if (req.method === 'GET' && (pathname === '/' || pathname === '/index.html')) {
    const htmlPath = path.join(PUBLIC_DIR, 'index.html');
    if (fs.existsSync(htmlPath)) {
      const html = fs.readFileSync(htmlPath);
      res.writeHead(200, { 'Content-Type': 'text/html; charset=utf-8' });
      return res.end(html);
    }
    return json(res, 404, { error: 'Frontend not found' });
  }

  // POST /api/register
  if (req.method === 'POST' && pathname === '/api/register') {
    let body;
    try { body = await readBody(req); }
    catch (e) { return json(res, 400, { error: 'Invalid JSON' }); }

    if (!body.name || !body.harness || !body.model) {
      return json(res, 400, { error: 'name, harness, and model are required' });
    }

    const api_key = 'ael_sk_' + crypto.randomBytes(24).toString('hex');
    try {
      db.createAgent({ id: body.name, api_key, harness: body.harness, model: body.model });
      return json(res, 201, { ok: true, agent_id: body.name, api_key });
    } catch (e) {
      if (e.message && e.message.includes('UNIQUE')) {
        return json(res, 409, { error: 'Agent name already taken' });
      }
      console.error('[api] register error:', e.message);
      return json(res, 500, { error: e.message });
    }
  }

  // GET /api/challenges/recommended  (must come before /:id)
  if (req.method === 'GET' && pathname === '/api/challenges/recommended') {
    const challenges = db.getAllChallenges();
    const counts     = db.getAttemptCounts();
    const stats      = db.getSolveStats();
    const sorted     = [...challenges].sort((a, b) => (counts[b.id] || 0) - (counts[a.id] || 0));
    return json(res, 200, sorted.map(ch => buildChallengeEntry(ch, stats[ch.id])));
  }

  // GET /api/challenges
  if (req.method === 'GET' && pathname === '/api/challenges') {
    const challenges = db.getAllChallenges();
    const stats      = db.getSolveStats();
    return json(res, 200, challenges.map(ch => buildChallengeEntry(ch, stats[ch.id])));
  }

  // GET /api/challenges/:id
  const chMatch = pathname.match(/^\/api\/challenges\/([^/]+)$/);
  if (req.method === 'GET' && chMatch) {
    const ch = db.getChallenge(chMatch[1]);
    if (!ch) return json(res, 404, { error: 'Not found' });
    const stats = db.getSolveStats();
    const entry = buildChallengeEntry(ch, stats[ch.id]);

    const challengeFile = path.join(__dirname, '..', 'challenges', `${chMatch[1]}.json`);
    try {
      const meta = JSON.parse(fs.readFileSync(challengeFile, 'utf8'));
      entry.body      = meta.issue?.body || meta.body || '';
      entry.fixDiff   = meta.fixDiff   || '';
      entry.fixCommit = meta.fixCommit || '';
    } catch (_) {}

    const subs = db.getSubmissionsByChallenge(chMatch[1]);
    entry.attempts = subs.map(s => {
      const agent = db.getAgent(s.agent_id);
      return {
        run_id:       s.run_id,
        model:        s.model,
        harness:      s.harness,
        passed:       !!s.tests_passed,
        time:         fmtTime(s.agent_time_seconds),
        test_time:    fmtTime(s.test_time_seconds || 0),
        diff_lines:   s.diff_lines,
        tests_ok:     s.tests_ok     || 0,
        tests_total:  s.tests_total  || 0,
        tests_failed: s.tests_failed || 0,
        agent_name:   agent ? agent.id : s.model,
        created_at:   s.created_at,
      };
    });

    return json(res, 200, entry);
  }

  // POST /api/submissions
  if (req.method === 'POST' && pathname === '/api/submissions') {
    let body;
    try { body = await readBody(req); }
    catch (e) { return json(res, 400, { error: 'Invalid JSON' }); }
    try {
      await processSubmission(body);
      return json(res, 201, { ok: true });
    } catch (e) {
      const status = e.status || 500;
      if (status !== 500) return json(res, status, { error: e.message });
      console.error('[api] processSubmission error:', e.message);
      return json(res, 500, { error: e.message });
    }
  }

  // GET /api/leaderboard
  if (req.method === 'GET' && pathname === '/api/leaderboard') {
    const agents = db.getAllAgents();
    return json(res, 200, agents.map((a, i) => buildAgentEntry(a, i + 1, agents)));
  }

  // GET /api/submissions/:id
  const subMatch = pathname.match(/^\/api\/submissions\/([^/]+)$/);
  if (req.method === 'GET' && subMatch) {
    const rawId = subMatch[1];
    let sub = db.getSubmission(rawId);
    if (!sub) {
      const intId = parseInt(rawId, 10);
      if (!isNaN(intId)) sub = db.getSubmissionById(intId);
    }
    if (!sub) return json(res, 404, { error: 'Not found' });

    const games = db.getGamesBySubmission(sub.id).map(g => {
      const oppSub = db.getSubmissionById(g.opponent_submission_id);
      return {
        opponent_id:        g.opponent_id,
        opponent_model:     g.opponent_model,
        score:              g.score,
        delta:              g.delta,
        rating_after:       g.rating_after,
        opponent_tests_ok:    oppSub ? oppSub.tests_ok    : null,
        opponent_tests_total: oppSub ? oppSub.tests_total : null,
        opponent_time:        oppSub ? oppSub.agent_time_seconds : null,
      };
    });

    return json(res, 200, {
      run_id:             sub.run_id,
      challenge_id:       sub.challenge_id,
      agent_id:           sub.agent_id,
      model:              sub.model,
      tests_ok:           sub.tests_ok,
      tests_total:        sub.tests_total,
      agent_time_seconds: sub.agent_time_seconds,
      diff_lines:         sub.diff_lines,
      diff:               sub.diff,
      exit_code:          sub.exit_code,
      games,
    });
  }

  // GET /api/agents/:id
  const agentMatch = pathname.match(/^\/api\/agents\/([^/]+)$/);
  if (req.method === 'GET' && agentMatch) {
    const agent = db.getAgent(agentMatch[1]);
    if (!agent) return json(res, 404, { error: 'Not found' });

    const allAgents = db.getAllAgents();
    const rank      = allAgents.findIndex(a => a.id === agent.id) + 1;
    const played    = agent.challenges_attempted || 0;
    // Compute wins/losses/draws from actual game data
    const allGames = db.getGamesByAgent(agent.id);
    const wins   = allGames.filter(g => g.score === 1).length;
    const losses = allGames.filter(g => g.score === 0).length;
    const draws  = allGames.filter(g => g.score === 0.5).length;

    const ratingHistory = db.getRatingHistory(agent.id).map(h => ({
      r:          h.rating_after,
      ts:         h.created_at,
      delta:      h.delta,
      score:      h.score,
      challenge:  h.challenge_id,
      opponent:   h.opponent_id,
    }));

    const configVersions = db.getConfigVersions(agent.id).map(cv => ({
      hash:         cv.agent_hash,
      model:        cv.model,
      first_seen_at: cv.first_seen_at,
    }));

    // Build matches: submissions with their game rows
    const allSubs = db.getSubmissionsByAgent(agent.id);
    const matches = allSubs.map(sub => {
      const games = db.getGamesBySubmission(sub.id, agent.id).map(g => {
        const oppSub = db.getSubmissionById(g.opponent_submission_id);
        return {
          opponent_id:          g.opponent_id,
          opponent_model:       g.opponent_model,
          score:                g.score,
          delta:                g.delta,
          rating_after:         g.rating_after,
          opponent_tests_ok:    oppSub ? oppSub.tests_ok    : null,
          opponent_tests_total: oppSub ? oppSub.tests_total : null,
          opponent_time:        oppSub ? oppSub.agent_time_seconds : null,
        };
      });
      const totalDelta = games.reduce((sum, g) => sum + (g.delta || 0), 0);
      return {
        submission_id: sub.id,
        run_id:        sub.run_id,
        challenge_id:  sub.challenge_id,
        tests_ok:      sub.tests_ok,
        tests_total:   sub.tests_total,
        tests_passed:  !!sub.tests_passed,
        agent_time:    sub.agent_time_seconds,
        diff_lines:    sub.diff_lines,
        exit_code:     sub.exit_code,
        created_at:    sub.created_at,
        games,
        total_delta:   Math.round(totalDelta * 10) / 10,
      };
    });

    return json(res, 200, {
      id:             agent.id,
      rank,
      harness:        agent.harness,
      model:          agent.model,
      current_hash:   agent.current_hash,
      elo:            Math.round(agent.rating),
      rd:             Math.round(agent.rd),
      played,
      wins,
      losses,
      draws,
      wr:             allGames.length > 0 ? wins / allGames.length : 0,
      d7:             ratingHistory.filter(h => {
                        const ts = new Date(h.ts).getTime();
                        return ts > Date.now() - 7 * 24 * 60 * 60 * 1000;
                      }).reduce((s, h) => s + (h.delta || 0), 0),
      ratingHistory,
      configVersions,
      matches,
    });
  }

  return json(res, 404, { error: 'Not found' });
}

// ── importChallenges ──────────────────────────────────────────────────────────

function importChallenges() {
  const challengesDir = path.join(__dirname, '..', 'challenges');
  if (!fs.existsSync(challengesDir)) return;
  const files = fs.readdirSync(challengesDir).filter(f => f.endsWith('.json'));
  let imported = 0;
  for (const f of files) {
    const id = f.replace('.json', '');
    const existing = db.getChallenge(id);
    if (existing && existing.repo) continue;
    try {
      const meta = JSON.parse(fs.readFileSync(path.join(challengesDir, f), 'utf8'));
      const fixDiff = meta.fixDiff || '';
      const diffLines = fixDiff.split('\n').filter(l => /^[+-]/.test(l) && !/^[+-]{3}/.test(l)).length;
      db.upsertChallenge({
        id,
        repo:        meta.repoUrl || meta.repo || '',
        title:       meta.issue?.title || meta.title || id,
        difficulty:  { filesChanged: 0, linesAdded: diffLines },
        testCommand: meta.testCommand,
        fixCommit:   meta.fixCommit,
      });
      imported++;
    } catch (_) {}
  }
  if (imported > 0) console.log(`[agentelo-api] imported ${imported} challenges from disk`);
}

// ── server ────────────────────────────────────────────────────────────────────

importChallenges();

const server = http.createServer((req, res) => {
  handleRequest(req, res).catch(err => {
    console.error('[api] unhandled error:', err);
    try { json(res, 500, { error: 'Internal server error' }); } catch (_) {}
  });
});

server.listen(PORT, () => {
  console.log(`[agentelo-api] listening on http://localhost:${PORT}`);
});
