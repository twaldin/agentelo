#!/usr/bin/env node
'use strict';

const http   = require('http');
const fs     = require('fs');
const path   = require('path');
const os     = require('os');
const crypto = require('crypto');
const { execFileSync } = require('child_process');
const db     = require('../core/db');
const { stripTestFiles, score } = require('../core/scorer');
const { computeScore, isPairwiseSubmissionExcluded, pickBetterSubmission } = require('../core/scoring');
const { computeRatings } = require('../core/bradley-terry');

const PORT       = process.env.PORT || 4000;
const PUBLIC_DIR = path.join(__dirname, '..', 'public');
const ACTIVE_DIR = path.join(__dirname, '..', 'challenges-active');
const FRONTEND_URL = process.env.FRONTEND_URL || 'http://localhost:3001';
const API_PATH_PREFIX = process.env.API_PATH_PREFIX || '';

const ALLOWED_ORIGINS_STRICT = process.env.ALLOWED_ORIGINS_STRICT === 'true';
const ALLOWED_ORIGINS_RAW = process.env.ALLOWED_ORIGINS || '*';
const ALLOWED_ORIGINS = ALLOWED_ORIGINS_RAW.split(',').map(o => o.trim()).filter(Boolean);

const TRUSTED_PROXIES = new Set(
  (process.env.TRUSTED_PROXIES ?? '127.0.0.1,::1').split(',').map(ip => ip.trim()).filter(Boolean)
);

const REGISTRATION_ENABLED = process.env.REGISTRATION_ENABLED === 'true';
const INVITE_CODES_ENV = (process.env.INVITE_CODES || '').split(',').map(c => c.trim()).filter(Boolean);
const VERIFICATION_ENABLED = process.env.VERIFICATION_ENABLED === 'true';
const TURNSTILE_SECRET = process.env.TURNSTILE_SECRET || '';
const CACHE_DIR = path.join(__dirname, '..', '.cache', 'repos');

const SUBMISSION_LIMIT_AGENT_PER_DAY = 5;
const SUBMISSION_LIMIT_IP_PER_DAY = 100;
const REGISTER_LIMIT_IP_PER_DAY = 3;

// Agents must attempt this many distinct challenges to appear on the leaderboard.
// Under this threshold they're in "placement" — ELO still tracked on their page,
// but they're not ranked (prevents low-sample noise from dominating the top).
const PLACEMENT_THRESHOLD = 10;

if (ALLOWED_ORIGINS_STRICT && ALLOWED_ORIGINS.includes('*')) {
  process.stderr.write('[agentelo-api] FATAL: ALLOWED_ORIGINS_STRICT=true but ALLOWED_ORIGINS is wildcard or unset — refusing to start\n');
  process.exit(1);
}
if (ALLOWED_ORIGINS.includes('*')) {
  process.stderr.write('[agentelo-api] WARNING: ALLOWED_ORIGINS is wildcard (*) — all origins allowed. Set ALLOWED_ORIGINS for production.\n');
}
if (!TURNSTILE_SECRET) {
  process.stderr.write('[agentelo-api] WARNING: TURNSTILE_SECRET is not set — CAPTCHA verification disabled (dev mode)\n');
}

const leaderboardCache = { data: null, minAgents: 0 };

// ── Verification worker helpers ───────────────────────────────────────────────

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

function slugify(str) {
  return str.replace(/[\/\\.:\s]+/g, '-').replace(/[^a-zA-Z0-9-]/g, '').toLowerCase();
}

function normalizeChallenge(raw) {
  return {
    id: raw.id,
    repo: raw.repoUrl || raw.repo,
    commit: raw.buggyCommit || raw.commit,
    fixCommit: raw.fixCommit,
    fixDiff: raw.fixDiff,
    title: raw.issue?.title || raw.title || raw.id,
    body: raw.issue?.body || raw.body || '',
    test_command: raw.testCommand || raw.test_command || 'npm test',
    baseline_passing: raw.baseline_passing || 0,
    broken_by_bug: raw.broken_by_bug || 0,
  };
}

function createInstalledWorkspace(challenge) {
  const repoSlug = slugify(challenge.repo.replace('https://github.com/', ''));
  const cacheDir = path.join(CACHE_DIR, repoSlug);
  if (!fs.existsSync(path.join(cacheDir, '.git', 'HEAD'))) return null;

  const wsDir = fs.mkdtempSync(path.join(os.tmpdir(), `agentelo-verify-ws-${challenge.id}-`));
  try {
    execFileSync('cp', ['-R', cacheDir + '/.', wsDir + '/'], { stdio: 'pipe', timeout: 120000 });
    execFileSync('git', ['checkout', '-f', challenge.commit], { cwd: wsDir, stdio: 'pipe' });
    execFileSync('git', ['clean', '-fd'], { cwd: wsDir, stdio: 'pipe' });

    if (fs.existsSync(path.join(wsDir, 'package.json'))) {
      try {
        execFileSync('npm', ['install', '--ignore-scripts'], { cwd: wsDir, stdio: 'pipe', timeout: 120000 });
      } catch (_) {
        try { execFileSync('npm', ['install'], { cwd: wsDir, stdio: 'pipe', timeout: 120000 }); } catch (_) {}
      }
    } else if (fs.existsSync(path.join(wsDir, 'pyproject.toml')) || fs.existsSync(path.join(wsDir, 'setup.py'))) {
      const venvDir = path.join(wsDir, '.venv');
      try {
        execFileSync('uv', ['venv', '-p', '3.12', venvDir], { cwd: wsDir, stdio: 'pipe', timeout: 60000 });
        const venvPython = path.join(venvDir, 'bin', 'python');
        try { execFileSync('uv', ['pip', 'install', '.', '--python', venvPython], { cwd: wsDir, stdio: 'pipe', timeout: 300000 }); } catch (_) {}
        for (const extra of ['.[tests]', '.[testing]', '.[dev,tests]', '.[dev]']) {
          try { execFileSync('uv', ['pip', 'install', extra, '--python', venvPython], { cwd: wsDir, stdio: 'pipe', timeout: 300000 }); } catch (_) {}
        }
        try { execFileSync('uv', ['pip', 'install', 'pytest', '--python', venvPython], { cwd: wsDir, stdio: 'pipe', timeout: 30000 }); } catch (_) {}
      } catch (_) {}
    }

    return wsDir;
  } catch (err) {
    try { fs.rmSync(wsDir, { recursive: true, force: true }); } catch (_) {}
    throw err;
  }
}

// ── BT rebuild debounce ───────────────────────────────────────────────────────

let _btDebounceTimer = null;
let _btPendingCount = 0;
const BT_DEBOUNCE_MS = 5000;
const BT_BATCH_TRIGGER = 10;

function scheduleBtRebuild() {
  _btPendingCount++;
  if (_btPendingCount >= BT_BATCH_TRIGGER) {
    _btPendingCount = 0;
    if (_btDebounceTimer) { clearTimeout(_btDebounceTimer); _btDebounceTimer = null; }
    rebuildBradleyTerry();
    leaderboardCache.data = null;
    return;
  }
  if (_btDebounceTimer) clearTimeout(_btDebounceTimer);
  _btDebounceTimer = setTimeout(() => {
    _btPendingCount = 0;
    _btDebounceTimer = null;
    rebuildBradleyTerry();
    leaderboardCache.data = null;
  }, BT_DEBOUNCE_MS);
}

// Build set of active challenge IDs from challenges-active/ directory
function getActiveChallengeIds() {
  if (!fs.existsSync(ACTIVE_DIR)) return new Set();
  return new Set(
    fs.readdirSync(ACTIVE_DIR)
      .filter(f => f.endsWith('.json'))
      .map(f => f.replace('.json', ''))
  );
}
const activeChallengeIds = getActiveChallengeIds();

// ── helpers ───────────────────────────────────────────────────────────────────

function json(res, status, data) {
  const body = JSON.stringify(data);
  res.writeHead(status, {
    'Content-Type': 'application/json',
    'Content-Length': Buffer.byteLength(body),
  });
  res.end(body);
}

function readBody(req) {
  return new Promise((resolve, reject) => {
    let data = '';
    req.on('data', chunk => { data += chunk; });
    req.on('end', () => {
      try { resolve(JSON.parse(data)); }
      catch (e) { reject(e); }
    });
    req.on('error', reject);
  });
}

function isMissingStringField(value) {
  return value == null || (typeof value === 'string' && value.trim() === '');
}

function validateSubmissionBody(body) {
  if (!body || typeof body !== 'object' || Array.isArray(body)) {
    return 'Request body must be a JSON object';
  }

  const requiredFields = ['api_key', 'run_id', 'challenge_id', 'agent_id', 'harness', 'model', 'diff'];
  for (const field of requiredFields) {
    if (isMissingStringField(body[field])) {
      return `Missing required field: ${field}`;
    }
  }

  const numericFields = [
    'tests_total',
    'tests_ok',
    'tests_failed',
    'agent_time_seconds',
    'test_time_seconds',
    'diff_lines',
    'exit_code',
    'tokens_in',
    'tokens_out',
    'cost_usd',
  ];
  for (const field of numericFields) {
    if (body[field] != null && (typeof body[field] !== 'number' || !Number.isFinite(body[field]))) {
      return `Field ${field} must be numeric`;
    }
  }

  if (typeof body.diff !== 'string') return 'Field diff must be a string';

  const testsTotal = body.tests_total != null ? body.tests_total : 0;
  const testsOk = body.tests_ok != null ? body.tests_ok : 0;
  if (testsOk > testsTotal) {
    return 'Invalid submission: tests_ok cannot be greater than tests_total';
  }

  return null;
}

function getClientIp(req) {
  const raw = (req.socket && req.socket.remoteAddress) || '';
  const remote = raw.startsWith('::ffff:') ? raw.slice(7) : raw;
  if (TRUSTED_PROXIES.has(remote) || TRUSTED_PROXIES.has(raw)) {
    const forwarded = req.headers['x-forwarded-for'];
    if (typeof forwarded === 'string' && forwarded.trim()) {
      return forwarded.split(',')[0].trim();
    }
  }
  return remote || 'unknown';
}

function secondsUntilNextUtcDay() {
  const now = new Date();
  const next = new Date(now);
  next.setUTCHours(24, 0, 0, 0);
  return Math.max(1, Math.ceil((next.getTime() - now.getTime()) / 1000));
}

function checkAndTrackRateLimit(agentId, ip) {
  // Bypass rate limits for localhost (seeding)
  if (ip === '127.0.0.1' || ip === '::1' || ip === 'localhost') {
    return { limited: false };
  }

  const windowDay = new Date().toISOString().slice(0, 10);
  const agentKey = `agent:${agentId}`;
  const ipKey = `ip:${ip}`;

  const reason = db.getDb().transaction(() => {
    if (db.getRateLimit(agentKey, windowDay) >= SUBMISSION_LIMIT_AGENT_PER_DAY) return 'agent';
    if (db.getRateLimit(ipKey, windowDay) >= SUBMISSION_LIMIT_IP_PER_DAY) return 'ip';
    db.incrRateLimit(agentKey, windowDay);
    db.incrRateLimit(ipKey, windowDay);
    return null;
  })();

  if (!reason) return { limited: false };
  return {
    limited: true,
    message: reason === 'agent'
      ? `Agent daily submission limit exceeded (${SUBMISSION_LIMIT_AGENT_PER_DAY}/day)`
      : `IP daily submission limit exceeded (${SUBMISSION_LIMIT_IP_PER_DAY}/day)`,
    retryAfterSeconds: secondsUntilNextUtcDay(),
  };
}

function resolveCorsOrigin(req) {
  if (ALLOWED_ORIGINS.includes('*')) return '*';
  const origin = req.headers.origin;
  if (origin && ALLOWED_ORIGINS.includes(origin)) return origin;
  return ALLOWED_ORIGINS[0] || 'null';
}

// Difficulty label based on actual solve rate (empirical difficulty).
// Requires at least MIN_ATTEMPTS_FOR_LABEL attempts to be statistically meaningful;
// below that, label as 'unrated'.
const MIN_ATTEMPTS_FOR_LABEL = 10;
function diffLabel(solveRate, attempts) {
  if ((attempts || 0) < MIN_ATTEMPTS_FOR_LABEL) return 'unrated';
  const sr = solveRate || 0;
  if (sr >= 0.6) return 'easy';
  if (sr >= 0.3) return 'medium';
  if (sr >= 0.1) return 'hard';
  return 'expert';
}

function fmtTime(secs) {
  if (!secs) return '—';
  const m = Math.floor(secs / 60);
  const s = Math.round(secs % 60);
  return m > 0 ? `${m}m ${s}s` : `${s}s`;
}

function detectLang(repo, testCommand) {
  if (!repo) return 'unknown';
  // Use test command as strongest signal
  if (testCommand) {
    const tc = testCommand.toLowerCase();
    if (tc.includes('pytest') || tc.includes('python') || tc.includes('tox')) return 'python';
  }
  const r = repo.toLowerCase();
  if (r.includes('django') || r.includes('flask') || r.includes('fastapi') || r.includes('python')) return 'python';
  if (r.includes('pallets/') || r.includes('marshmallow') || r.includes('psf/') || r.includes('jinja') || r.includes('click') || r.includes('werkzeug')) return 'python';
  if (r.includes('angular') || r.includes('react') || r.includes('next') || r.includes('vue') || r.includes('svelte')) return 'typescript';
  if (r.includes('golang') || r.includes('/go') || r.includes('tokio') || r.includes('rust')) return 'rust';
  return 'javascript';
}

// ── Bradley-Terry rebuild ─────────────────────────────────────────────────────
// Recomputes all ratings from scratch. Called after each new submission.
// With ~150 agents and ~3000 submissions, completes in <1 second.
function rebuildBradleyTerry() {
  const CHALLENGES_DIR = path.join(__dirname, '..', 'challenges-active');
  const baselineCache = {};
  function getBaseline(challengeId) {
    if (baselineCache[challengeId] !== undefined) return baselineCache[challengeId];
    try {
      const meta = JSON.parse(fs.readFileSync(path.join(CHALLENGES_DIR, `${challengeId}.json`), 'utf8'));
      baselineCache[challengeId] = { baseline_passing: meta.baseline_passing ?? null };
    } catch {
      baselineCache[challengeId] = { baseline_passing: null };
    }
    return baselineCache[challengeId];
  }

  // Clear games, reset agents
  db.getDb().exec('DELETE FROM games');
  const agents = db.getAllAgents();
  for (const agent of agents) {
    db.updateAgent({
      id: agent.id, rating: 1500, rd: 0, volatility: 0,
      wins: 0, challenges_attempted: 0, current_hash: agent.current_hash,
    });
  }

  // Build pairwise outcomes — only verified submissions count toward ratings
  const allSubs = db.getDb().prepare("SELECT * FROM submissions WHERE verification_status = 'verified' ORDER BY created_at ASC").all()
    .filter(sub => !isPairwiseSubmissionExcluded(sub));
  const byChallenge = {};
  for (const s of allSubs) {
    if (!byChallenge[s.challenge_id]) byChallenge[s.challenge_id] = [];
    byChallenge[s.challenge_id].push(s);
  }
  for (const [chId, subs] of Object.entries(byChallenge)) {
    const best = {};
    for (const s of subs) best[s.agent_id] = pickBetterSubmission(best[s.agent_id], s);
    byChallenge[chId] = Object.values(best);
  }

  const outcomes = new Map();
  const challengesPerAgent = new Map();
  const winsPerAgent = new Map();
  const pairwiseGames = [];

  function getRecord(a, b) {
    if (!outcomes.has(a)) outcomes.set(a, new Map());
    const aMap = outcomes.get(a);
    if (!aMap.has(b)) aMap.set(b, { wins: 0, losses: 0, draws: 0 });
    return aMap.get(b);
  }

  for (const [challengeId, subs] of Object.entries(byChallenge)) {
    const { baseline_passing } = getBaseline(challengeId);
    for (const sub of subs) {
      challengesPerAgent.set(sub.agent_id, (challengesPerAgent.get(sub.agent_id) || 0) + 1);
    }
    for (let i = 0; i < subs.length; i++) {
      for (let j = i + 1; j < subs.length; j++) {
        const subA = subs[i], subB = subs[j];
        if (subA.agent_id === subB.agent_id) continue;
        const scoreA = computeScore(subA, subB, { baseline_passing });
        const scoreB = scoreA === 1 ? 0 : scoreA === 0 ? 1 : 0.5;
        const recAB = getRecord(subA.agent_id, subB.agent_id);
        const recBA = getRecord(subB.agent_id, subA.agent_id);
        if (scoreA === 1) { recAB.wins++; recBA.losses++; winsPerAgent.set(subA.agent_id, (winsPerAgent.get(subA.agent_id) || 0) + 1); }
        else if (scoreA === 0) { recAB.losses++; recBA.wins++; winsPerAgent.set(subB.agent_id, (winsPerAgent.get(subB.agent_id) || 0) + 1); }
        else { recAB.draws++; recBA.draws++; }
        pairwiseGames.push({ challengeId, subA, subB, scoreA, scoreB });
      }
    }
  }

  const ratings = computeRatings(outcomes);

  // Update agents
  for (const [agentId, rating] of ratings) {
    const agent = db.getAgent(agentId);
    if (!agent) continue;
    db.updateAgent({
      id: agentId, rating, rd: 0, volatility: 0,
      wins: winsPerAgent.get(agentId) || 0,
      challenges_attempted: challengesPerAgent.get(agentId) || 0,
      current_hash: agent.current_hash,
    });
  }

  // Insert game records
  for (const { challengeId, subA, subB, scoreA, scoreB } of pairwiseGames) {
    const ratingA = ratings.get(subA.agent_id) || 1500;
    const ratingB = ratings.get(subB.agent_id) || 1500;
    db.insertGame({ challenge_id: challengeId, agent_id: subA.agent_id, opponent_id: subB.agent_id,
      submission_id: subA.id, opponent_submission_id: subB.id, score: scoreA,
      rating_before: ratingA, rating_after: ratingA, rd_before: 0, rd_after: 0, delta: 0,
      opponent_rating: ratingB, opponent_rd: 0, opponent_model: subB.model });
    db.insertGame({ challenge_id: challengeId, agent_id: subB.agent_id, opponent_id: subA.agent_id,
      submission_id: subB.id, opponent_submission_id: subA.id, score: scoreB,
      rating_before: ratingB, rating_after: ratingB, rd_before: 0, rd_after: 0, delta: 0,
      opponent_rating: ratingA, opponent_rd: 0, opponent_model: subA.model });
  }

  // Save snapshots
  for (const [agentId, rating] of ratings) {
    db.insertRatingSnapshot({
      agent_id: agentId, rating,
      wins: winsPerAgent.get(agentId) || 0,
      challenges_attempted: challengesPerAgent.get(agentId) || 0,
    });
  }

  console.log(`[api] BT rebuild: ${ratings.size} agents, ${pairwiseGames.length * 2} games`);
}

function buildChallengeEntry(row, stats) {
  const s = stats || { total: 0, wins: 0, avg_time: 0, avg_agent_time: 0 };

  // Compute baseline-relative solve rate (how many agents actually fixed tests)
  let sr = 0;
  if (s.total > 0) {
    const chFile = path.join(__dirname, '..', 'challenges-active', `${row.id}.json`);
    let bl = 0;
    try { const m = JSON.parse(fs.readFileSync(chFile, 'utf8')); bl = m.baseline_passing || 0; } catch {}
    if (bl > 0) {
      // Count verified submissions that fixed at least 1 test beyond baseline
      const subs = db.getSubmissionsByChallenge(row.id).filter(sub => sub.verification_status === 'verified');
      const solved = subs.filter(sub => (sub.tests_ok || 0) > bl).length;
      sr = solved / s.total;
    } else {
      sr = s.wins / s.total;
    }
  }

  return {
    id:           row.id,
    repo:         (row.repo || '').replace('https://github.com/', ''),
    title:        row.title || row.id,
    diff:         diffLabel(sr, s.total || 0),
    lang:         detectLang(row.repo, row.test_command),
    sr,
    att:          s.total || 0,
    avgt:         fmtTime(s.avg_agent_time || s.avg_time),
    test_command: row.test_command,
    created_at:   row.created_at,
  };
}

function buildAgentEntry(agent, rank, allAgents) {
  const snapshots = db.getRatingSnapshots(agent.id);
  const hist      = snapshots.slice(-10).map(s => Math.round(s.rating));

  // d7: rating change over last 7 days (from snapshots)
  // If no snapshot before the 7d window, use the agent's first snapshot
  // (i.e. their entire rating journey since creation within this week)
  const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
  const prevSnapshot = db.getPreviousSnapshots(agent.id, sevenDaysAgo);
  const baseRating = prevSnapshot ? prevSnapshot.rating : (snapshots.length > 0 ? snapshots[0].rating : agent.rating);
  const d7 = agent.rating - baseRating;

  const subs   = db.getSubmissionsByAgent(agent.id).filter(s => s.verification_status === 'verified').slice(0, 3);
  const recent = subs.map(s => {
    const ch = db.getChallenge(s.challenge_id);
    // Use tests_fixed (not raw tests_ok) for pass/fail status
    const chFile = path.join(__dirname, '..', 'challenges-active', `${s.challenge_id}.json`);
    let bl = 0;
    try { const m = JSON.parse(fs.readFileSync(chFile, 'utf8')); bl = m.baseline_passing || 0; } catch {}
    const fixed = Math.max(0, (s.tests_ok || 0) - bl);
    return {
      n:  ch ? ch.repo.replace('https://github.com/', '').split('/')[1] + '/' + s.challenge_id : s.challenge_id,
      st: fixed > 0 ? 'pass' : 'fail',
      sc: fixed > 0 ? '✓' : '✗',
      t:  fmtTime(s.agent_time_seconds),
    };
  });

  const games  = db.getGamesByAgent(agent.id);
  const gWins  = games.filter(g => g.score === 1).length;
  const played = games.length;

  return {
    id:      agent.id,
    rank,
    name:    agent.display_name || agent.id,
    display_name: agent.display_name || agent.id,
    harness: agent.harness,
    model:   agent.model,
    elo:     Math.round(agent.rating),
    rd:      Math.round(agent.rd),
    wr:      played > 0 ? gWins / played : 0,
    played,
    wins:    gWins,
    d7:      Math.round(d7),
    hist,
    hash:    agent.current_hash ? agent.current_hash.slice(0, 8) : null,
    recent,
    avgCost: (() => {
      const allSubs = db.getSubmissionsByAgent(agent.id);
      const withCost = allSubs.filter(s => s.cost_usd > 0);
      return withCost.length > 0 ? withCost.reduce((sum, s) => sum + s.cost_usd, 0) / withCost.length : null;
    })(),
  };
}

// ── processSubmission ─────────────────────────────────────────────────────────

async function processSubmission(body, authenticatedAgent) {
  // 1. Authenticate via api_key
  const agent = authenticatedAgent || db.getAgentByKey(body.api_key);
  if (!agent) throw Object.assign(new Error('Invalid API key'), { status: 401 });
  if (body.agent_id !== agent.id) {
    throw Object.assign(new Error('agent_id does not match authenticated API key'), { status: 400 });
  }

  // 2. Track config version changes
  if (agent.current_hash !== body.agent_hash) {
    db.insertConfigVersion({
      agent_id:     agent.id,
      agent_hash:   body.agent_hash,
      harness:      body.harness || agent.harness,
      model:        body.model   || agent.model,
      config_files: body.config_files || [],
    });
  }

  // 3. Upsert challenge
  const challengeFile = path.join(__dirname, '..', 'challenges-active', `${body.challenge_id}.json`);
  let challengeMeta = null;
  try { challengeMeta = JSON.parse(fs.readFileSync(challengeFile, 'utf8')); } catch (_) {}

  const existing = db.getChallenge(body.challenge_id);
  if (!existing || !existing.repo) {
    const repo     = body.repo || (challengeMeta && (challengeMeta.repoUrl || challengeMeta.repo)) || '';
    const title    = (challengeMeta && challengeMeta.issue && challengeMeta.issue.title) || body.challenge_id;
    const fixDiff  = (challengeMeta && challengeMeta.fixDiff) || '';
    const diffLines = fixDiff.split('\n').filter(l => /^[+-]/.test(l) && !/^[+-]{3}/.test(l)).length;
    db.upsertChallenge({
      id:          body.challenge_id,
      repo,
      title,
      difficulty:  { filesChanged: 0, linesAdded: diffLines },
      testCommand: challengeMeta && challengeMeta.testCommand,
      fixCommit:   challengeMeta && challengeMeta.fixCommit,
    });
  }

  // 4. Insert submission — pending if server-side verification is enabled
  db.insertSubmission({
    run_id:             body.run_id,
    challenge_id:       body.challenge_id,
    agent_id:           agent.id,
    agent_hash:         body.agent_hash || '',
    harness:            body.harness    || agent.harness,
    model:              body.model      || agent.model,
    tests_passed:       body.tests_passed ? 1 : 0,
    tests_total:        body.tests_total  || 0,
    tests_ok:           body.tests_ok     || 0,
    tests_failed:       body.tests_failed || 0,
    agent_time_seconds: body.agent_time_seconds || 0,
    test_time_seconds:  body.test_time_seconds  || 0,
    rating_at_submission: agent.rating,
    rd_at_submission:     agent.rd,
    diff_lines:         body.diff_lines  || 0,
    diff:               body.diff        || '',
    exit_code:          body.exit_code  != null ? body.exit_code : 1,
    tampered:           body.tampered   ? 1 : 0,
    transcript_path:    body.log_file   || null,
    tokens_in:          body.tokens_in   || 0,
    tokens_out:         body.tokens_out  || 0,
    cost_usd:           body.cost_usd    || 0,
    created_at:         body.finished_at || new Date().toISOString(),
    verification_status: VERIFICATION_ENABLED ? 'pending' : 'verified',
  });

  // 5. Get inserted submission's integer id
  const mySub = db.getSubmission(body.run_id);
  if (!mySub) throw new Error('Failed to retrieve inserted submission');

  if (!VERIFICATION_ENABLED) {
    // Immediate mode: rebuild ratings now, return 201 (same behavior as before)
    rebuildBradleyTerry();
    return { status: 201, body: { ok: true } };
  }

  // Verification enabled: worker will score and rebuild asynchronously
  return { status: 202, body: { status: 'pending', run_id: body.run_id, verification_eta_seconds: 60 } };
}

// ── Verification worker ───────────────────────────────────────────────────────

async function verifySubmission(sub) {
  const now = new Date().toISOString();

  const challengeFile = path.join(ACTIVE_DIR, `${sub.challenge_id}.json`);
  let challengeMeta;
  try {
    challengeMeta = normalizeChallenge(JSON.parse(fs.readFileSync(challengeFile, 'utf8')));
  } catch (_) {
    db.updateSubmissionVerification(sub.id, { verification_status: 'rejected', verification_note: 'CHALLENGE_FILE_MISSING', verified_at: now });
    return;
  }

  const repoSlug = slugify(challengeMeta.repo.replace('https://github.com/', ''));
  const cacheDir = path.join(CACHE_DIR, repoSlug);
  if (!fs.existsSync(path.join(cacheDir, '.git', 'HEAD'))) {
    db.updateSubmissionVerification(sub.id, { verification_status: 'rejected', verification_note: 'NO_REPO_CACHE', verified_at: now });
    return;
  }

  let wsDir;
  try {
    wsDir = createInstalledWorkspace(challengeMeta);
  } catch (err) {
    db.updateSubmissionVerification(sub.id, {
      verification_status: 'rejected',
      verification_note: `WORKSPACE_FAILED: ${(err.message || '').slice(0, 120)}`,
      verified_at: now,
    });
    return;
  }
  if (!wsDir) {
    db.updateSubmissionVerification(sub.id, { verification_status: 'rejected', verification_note: 'NO_REPO_CACHE', verified_at: now });
    return;
  }

  const workDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agentelo-verify-'));
  let result;
  try {
    execFileSync('cp', ['-R', wsDir + '/.', workDir + '/'], { stdio: 'pipe', timeout: 30000 });
    let timeoutHandle;
    const scorePromise = score(sub.diff || '', workDir, challengeMeta, null);
    const timeoutPromise = new Promise((_, reject) => {
      timeoutHandle = setTimeout(() => reject(new Error('TIMEOUT')), 180000);
    });
    try {
      result = await Promise.race([scorePromise, timeoutPromise]);
    } finally {
      clearTimeout(timeoutHandle);
    }
  } catch (err) {
    const note = err.message === 'TIMEOUT' ? 'TIMEOUT' : `SCORE_ERROR: ${(err.message || '').slice(0, 100)}`;
    db.updateSubmissionVerification(sub.id, { verification_status: 'rejected', verification_note: note, verified_at: now });
    return;
  } finally {
    try { fs.rmSync(workDir, { recursive: true, force: true }); } catch (_) {}
    try { fs.rmSync(wsDir,   { recursive: true, force: true }); } catch (_) {}
  }

  const warnings = result.warnings || [];
  const critical = warnings.filter(w => w === 'DIFF_APPLY_FAILED' || w === 'TEST_INJECTION_FAILED');
  if (critical.length > 0) {
    db.updateSubmissionVerification(sub.id, { verification_status: 'rejected', verification_note: critical.join(','), verified_at: now });
    return;
  }

  const serverOk = result.tests_ok || 0;
  const clientOk = sub.tests_ok || 0;

  if (Math.abs(serverOk - clientOk) <= 2) {
    db.updateSubmissionVerification(sub.id, {
      verification_status: 'verified',
      verified_at: now,
      server_tests_ok: serverOk,
    });
  } else {
    db.updateSubmissionVerification(sub.id, {
      verification_status: 'verified',
      verification_note: `server: ${serverOk}, client: ${clientOk}, override`,
      verified_at: now,
      server_tests_ok: serverOk,
      tests_ok: serverOk,
    });
  }

  console.log(`[verify] ${sub.run_id}: server=${serverOk} client=${clientOk} → verified`);
  scheduleBtRebuild();
}

async function verificationWorker() {
  console.log('[verify] worker started');
  while (true) {
    try {
      let pending;
      try {
        pending = db.getDb().prepare(
          "SELECT * FROM submissions WHERE verification_status = 'pending' ORDER BY created_at LIMIT 1"
        ).get();
      } catch (err) {
        console.error('[verify] queue poll error:', err.message);
        await sleep(5000);
        continue;
      }

      if (!pending) {
        await sleep(5000);
        continue;
      }

      try {
        await verifySubmission(pending);
      } catch (err) {
        console.error(`[verify] unhandled error for ${pending.run_id}:`, err.message);
        try {
          db.updateSubmissionVerification(pending.id, {
            verification_status: 'rejected',
            verification_note: `WORKER_ERROR: ${(err.message || '').slice(0, 100)}`,
            verified_at: new Date().toISOString(),
          });
        } catch (_) {}
      }
    } catch (err) {
      console.error('[verify] fatal loop error, restarting in 10s:', err.message);
      await sleep(10000);
    }
  }
}

// ── router ────────────────────────────────────────────────────────────────────

async function handleRequest(req, res) {
  const url      = new URL(req.url, `http://localhost:${PORT}`);
  let pathname = url.pathname;
  if (API_PATH_PREFIX && pathname.startsWith(API_PATH_PREFIX)) {
    pathname = pathname.slice(API_PATH_PREFIX.length) || '/';
  }
  const corsOrigin = resolveCorsOrigin(req);

  res.setHeader('Access-Control-Allow-Origin', corsOrigin);
  if (corsOrigin !== '*') res.setHeader('Vary', 'Origin');

  if (req.method === 'OPTIONS') {
    res.writeHead(204, {
      'Access-Control-Allow-Origin':  corsOrigin,
      'Access-Control-Allow-Methods': 'GET,POST,PATCH',
      'Access-Control-Allow-Headers': 'Content-Type',
    });
    return res.end();
  }

  // Frontend — redirect to Next.js app on :3001
  if (req.method === 'GET' && (pathname === '/' || pathname === '/index.html')) {
    res.writeHead(302, { 'Location': FRONTEND_URL });
    return res.end();
  }

  // POST /api/register
  if (req.method === 'POST' && pathname === '/api/register') {
    // Rate limit: 3/IP/day (bypass for localhost)
    const regIp = getClientIp(req);
    if (!(regIp === '127.0.0.1' || regIp === '::1' || regIp === 'localhost')) {
      const windowDay = new Date().toISOString().slice(0, 10);
      const regKey = `reg:ip:${regIp}`;
      const limited = db.getDb().transaction(() => {
        if (db.getRateLimit(regKey, windowDay) >= REGISTER_LIMIT_IP_PER_DAY) return true;
        db.incrRateLimit(regKey, windowDay);
        return false;
      })();
      if (limited) {
        res.setHeader('Retry-After', String(secondsUntilNextUtcDay()));
        return json(res, 429, { error: `Registration rate limit exceeded (${REGISTER_LIMIT_IP_PER_DAY}/day per IP)` });
      }
    }

    let body;
    try { body = await readBody(req); }
    catch (e) { return json(res, 400, { error: 'Invalid JSON' }); }

    if (TURNSTILE_SECRET) {
      const token = body.captcha_token ? String(body.captcha_token) : '';
      if (!token) {
        return json(res, 403, { error: 'CAPTCHA token required' });
      }
      let tsData;
      try {
        const tsRes = await fetch('https://challenges.cloudflare.com/turnstile/v0/siteverify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams({ secret: TURNSTILE_SECRET, response: token, remoteip: regIp }),
        });
        tsData = await tsRes.json();
      } catch (e) {
        console.error('[api] turnstile verify error:', e.message);
        return json(res, 503, { error: 'CAPTCHA verification unavailable' });
      }
      if (!tsData.success) {
        return json(res, 403, { error: 'CAPTCHA verification failed' });
      }
    }

    if (!body.name || !body.harness || !body.model) {
      return json(res, 400, { error: 'name, harness, and model are required' });
    }

    const api_key = 'ael_sk_' + crypto.randomBytes(24).toString('hex');
    try {
      db.getDb().transaction(() => {
        if (!REGISTRATION_ENABLED) {
          const code = body.invite_code ? String(body.invite_code).trim() : '';
          if (!code) {
            const err = new Error('Registration closed — invite code required');
            err.inviteRequired = true;
            throw err;
          }
          if (INVITE_CODES_ENV.includes(code)) {
            db.getDb().prepare('INSERT OR IGNORE INTO invite_codes (code, note) VALUES (?, ?)').run(code, 'env');
          }
          const row = db.getInviteCode(code);
          if (!row || row.used_by_agent) {
            const err = new Error('Registration closed — invite code required');
            err.inviteRequired = true;
            throw err;
          }
          db.createAgent({ id: body.name, api_key, harness: body.harness, model: body.model, display_name: body.name });
          db.markInviteCodeUsed(code, body.name);
        } else {
          db.createAgent({ id: body.name, api_key, harness: body.harness, model: body.model, display_name: body.name });
        }
      })();
      req._logAgentId = body.name;
      return json(res, 201, { ok: true, agent_id: body.name, api_key });
    } catch (e) {
      if (e.inviteRequired) return json(res, 403, { error: e.message });
      if (e.message && e.message.includes('UNIQUE')) {
        return json(res, 409, { error: 'Agent name already registered' });
      }
      console.error('[api] register error:', e.message);
      return json(res, 500, { error: e.message });
    }
  }

  // GET /api/challenges/recommended  (must come before /:id)
  if (req.method === 'GET' && pathname === '/api/challenges/recommended') {
    const challenges = db.getAllChallenges().filter(ch => activeChallengeIds.has(ch.id));
    const counts     = db.getAttemptCounts();
    const stats      = db.getSolveStats();
    const sorted     = [...challenges].sort((a, b) => (counts[b.id] || 0) - (counts[a.id] || 0));
    return json(res, 200, sorted.map(ch => buildChallengeEntry(ch, stats[ch.id])));
  }

  // GET /api/challenges
  if (req.method === 'GET' && pathname === '/api/challenges') {
    const challenges = db.getAllChallenges().filter(ch => activeChallengeIds.has(ch.id));
    const stats      = db.getSolveStats();
    return json(res, 200, challenges.map(ch => buildChallengeEntry(ch, stats[ch.id])));
  }

  // GET /api/challenges/:id/fix
  const chFixMatch = pathname.match(/^\/api\/challenges\/([^/]+)\/fix$/);
  if (req.method === 'GET' && chFixMatch) {
    const challengeId = chFixMatch[1];
    const ch = db.getChallenge(challengeId);
    if (!ch) return json(res, 404, { error: 'Not found' });

    const apiKey = url.searchParams.get('api_key');
    if (!apiKey) return json(res, 401, { error: 'api_key query param is required' });
    const agent = db.getAgentByKey(apiKey);
    if (!agent) return json(res, 401, { error: 'Invalid API key' });

    const hasSubmitted = db.getSubmissionsByChallenge(challengeId).some(s => s.agent_id === agent.id);
    if (!hasSubmitted) {
      return json(res, 403, { error: 'Fix data is only available after your first submission on this challenge' });
    }

    const challengeFile = path.join(__dirname, '..', 'challenges-active', `${challengeId}.json`);
    try {
      const meta = JSON.parse(fs.readFileSync(challengeFile, 'utf8'));
      return json(res, 200, {
        id: challengeId,
        fixDiff: meta.fixDiff || '',
        fixCommit: meta.fixCommit || '',
        baseline_passing: meta.baseline_passing != null ? meta.baseline_passing : null,
      });
    } catch (_) {
      return json(res, 404, { error: 'Challenge fix data not found' });
    }
  }

  // GET /api/challenges/:id
  const chMatch = pathname.match(/^\/api\/challenges\/([^/]+)$/);
  if (req.method === 'GET' && chMatch) {
    const ch = db.getChallenge(chMatch[1]);
    if (!ch) return json(res, 404, { error: 'Not found' });
    const stats = db.getSolveStats();
    const entry = buildChallengeEntry(ch, stats[ch.id]);

    const challengeFile = path.join(__dirname, '..', 'challenges-active', `${chMatch[1]}.json`);
    let baseline_passing = null;
    let broken_by_bug = null;
    try {
      const meta = JSON.parse(fs.readFileSync(challengeFile, 'utf8'));
      entry.body      = meta.issue?.body || meta.body || '';
      entry.repoUrl      = meta.repoUrl || meta.repo || '';
      entry.buggyCommit  = meta.buggyCommit || '';
      entry.testCommand  = meta.testCommand || meta.test_command || 'npm test';
      baseline_passing = meta.baseline_passing != null ? meta.baseline_passing : null;
      broken_by_bug    = meta.broken_by_bug    != null ? meta.broken_by_bug    : null;
    } catch (_) {}
    entry.broken_by_bug    = broken_by_bug;

    const subs = db.getSubmissionsByChallenge(chMatch[1]);
    entry.attempts = subs.map(s => {
      const agent = db.getAgent(s.agent_id);
      // Use tests_fixed for passed flag, not raw tests_ok
      const fixed = (baseline_passing != null) ? Math.max(0, (s.tests_ok || 0) - baseline_passing) : (s.tests_ok || 0);
      return {
        run_id:       s.run_id,
        model:        s.model,
        harness:      s.harness,
        passed:       fixed > 0,
        time:         fmtTime(s.agent_time_seconds),
        test_time:    fmtTime(s.test_time_seconds || 0),
        diff_lines:   s.diff_lines,
        tests_ok:     s.tests_ok     || 0,
        tests_total:  s.tests_total  || 0,
        tests_failed: s.tests_failed || 0,
        broken_by_bug:    broken_by_bug,
        cost_usd:     s.cost_usd || 0,
        agent_name:   agent ? (agent.display_name || agent.id) : s.model,
        created_at:   s.created_at,
      };
    });

    return json(res, 200, entry);
  }

  // POST /api/submissions
  if (req.method === 'POST' && pathname === '/api/submissions') {
    let body;
    try { body = await readBody(req); }
    catch (e) { return json(res, 400, { error: 'Invalid JSON' }); }

    const validationError = validateSubmissionBody(body);
    if (validationError) return json(res, 400, { error: validationError });

    const agent = db.getAgentByKey(body.api_key);
    if (!agent) return json(res, 401, { error: 'Invalid API key' });
    if (body.agent_id !== agent.id) {
      return json(res, 400, { error: 'agent_id does not match authenticated API key' });
    }
    req._logAgentId = agent.id;

    const limit = checkAndTrackRateLimit(agent.id, getClientIp(req));
    if (limit.limited) {
      res.setHeader('Retry-After', String(limit.retryAfterSeconds));
      return json(res, 429, { error: limit.message });
    }

    try {
      const result = await processSubmission(body, agent);
      return json(res, result.status, result.body);
    } catch (e) {
      const status = e.status || 500;
      if (status !== 500) return json(res, status, { error: e.message });
      console.error('[api] processSubmission error:', e.message);
      return json(res, 500, { error: e.message });
    }
  }

  // GET /api/leaderboard (cached — only updates every 30s to prevent mid-rebuild flicker)
  if (req.method === 'GET' && pathname === '/api/leaderboard') {
    const now = Date.now();
    if (!leaderboardCache.data || now - leaderboardCache.updatedAt > 30000) {
      const agents = db.getAllAgents().filter(a => a.challenges_attempted >= PLACEMENT_THRESHOLD);
      // Only update cache if we have a reasonable number of agents (rebuild not in progress)
      if (agents.length >= (leaderboardCache.minAgents || 1) * 0.8 || !leaderboardCache.data) {
        leaderboardCache.data = agents.map((a, i) => buildAgentEntry(a, i + 1, agents));
        leaderboardCache.minAgents = Math.max(leaderboardCache.minAgents || 0, agents.length);
        leaderboardCache.updatedAt = now;
      }
    }
    return json(res, 200, leaderboardCache.data || []);
  }

  // GET /api/submissions/:run_id/status  (verification polling)
  const subStatusMatch = pathname.match(/^\/api\/submissions\/([^/]+)\/status$/);
  if (req.method === 'GET' && subStatusMatch) {
    const sub = db.getSubmission(subStatusMatch[1]);
    if (!sub) return json(res, 404, { error: 'Not found' });
    return json(res, 200, {
      run_id: sub.run_id,
      status: sub.verification_status || 'verified',
      verification_note: sub.verification_note || null,
      server_tests_ok: sub.server_tests_ok != null ? sub.server_tests_ok : null,
    });
  }

  // GET /api/submissions/:id
  const subMatch = pathname.match(/^\/api\/submissions\/([^/]+)$/);
  if (req.method === 'GET' && subMatch) {
    const rawId = subMatch[1];
    let sub = db.getSubmission(rawId);
    if (!sub) {
      const intId = parseInt(rawId, 10);
      if (!isNaN(intId)) sub = db.getSubmissionById(intId);
    }
    if (!sub) return json(res, 404, { error: 'Not found' });

    // Get challenge baseline for relative scoring
    const chFile = path.join(__dirname, '..', 'challenges-active', `${sub.challenge_id}.json`);
    let blPass = null, blBroken = null;
    try {
      const meta = JSON.parse(fs.readFileSync(chFile, 'utf8'));
      blPass = meta.baseline_passing; blBroken = meta.broken_by_bug;
    } catch {}

    const games = db.getGamesBySubmission(sub.id).map(g => {
      const oppSub = db.getSubmissionById(g.opponent_submission_id);
      return {
        id:                   g.id,
        opponent_id:          g.opponent_id,
        opponent_model:       g.opponent_model,
        opponent_submission_id: g.opponent_submission_id,
        score:                g.score,
        delta:                g.delta,
        rating_after:         g.rating_after,
        opponent_tests_ok:    oppSub ? oppSub.tests_ok    : null,
        opponent_tests_total: oppSub ? oppSub.tests_total : null,
        opponent_time:        oppSub ? oppSub.agent_time_seconds : null,
        opponent_diff_lines:  oppSub ? oppSub.diff_lines  : null,
      };
    });

    const ch = db.getChallenge(sub.challenge_id);

    return json(res, 200, {
      id:                 sub.id,
      run_id:             sub.run_id,
      challenge_id:       sub.challenge_id,
      challenge_title:    ch ? ch.title : sub.challenge_id,
      agent_id:           sub.agent_id,
      harness:            sub.harness,
      model:              sub.model,
      tests_ok:           sub.tests_ok,
      tests_total:        sub.tests_total,
      tests_failed:       sub.tests_failed,
      baseline_passing:   blPass,
      broken_by_bug:      blBroken,
      agent_time_seconds: sub.agent_time_seconds,
      test_time_seconds:  sub.test_time_seconds,
      diff_lines:         sub.diff_lines,
      diff:               stripTestFiles(sub.diff || ''),
      exit_code:          sub.exit_code,
      tampered:           !!sub.tampered,
      tokens_in:          sub.tokens_in || 0,
      tokens_out:         sub.tokens_out || 0,
      cost_usd:           sub.cost_usd || 0,
      created_at:         sub.created_at,
      games,
    });
  }

  // GET /api/agents/:id
  const agentMatch = pathname.match(/^\/api\/agents\/([^/]+)$/);
  if (req.method === 'PATCH' && agentMatch) {
    let body;
    try { body = await readBody(req); }
    catch (e) { return json(res, 400, { error: 'Invalid JSON' }); }

    if (isMissingStringField(body && body.api_key)) {
      return json(res, 400, { error: 'Missing required field: api_key' });
    }
    if (isMissingStringField(body && body.display_name)) {
      return json(res, 400, { error: 'Missing required field: display_name' });
    }

    const displayName = String(body.display_name).trim();
    if (!displayName) return json(res, 400, { error: 'display_name cannot be empty' });

    const requestingAgent = db.getAgentByKey(body.api_key);
    if (!requestingAgent) return json(res, 401, { error: 'Invalid API key' });
    if (requestingAgent.id !== agentMatch[1]) {
      return json(res, 403, { error: 'API key does not have permission to update this agent' });
    }

    const existing = db.getAgent(agentMatch[1]);
    if (!existing) return json(res, 404, { error: 'Not found' });

    db.setAgentDisplayName(existing.id, displayName);
    leaderboardCache.data = null;

    return json(res, 200, { ok: true, id: existing.id, display_name: displayName });
  }

  if (req.method === 'GET' && agentMatch) {
    const agent = db.getAgent(agentMatch[1]);
    if (!agent) return json(res, 404, { error: 'Not found' });

    // Rank only against qualified agents (same filter as leaderboard).
    // Placement agents (under threshold) return rank=null and a placement object.
    const qualified = db.getAllAgents().filter(a => a.challenges_attempted >= PLACEMENT_THRESHOLD);
    const isQualified = (agent.challenges_attempted || 0) >= PLACEMENT_THRESHOLD;
    const rank = isQualified ? (qualified.findIndex(a => a.id === agent.id) + 1) : null;
    const placement = isQualified ? null : {
      attempted: agent.challenges_attempted || 0,
      required: PLACEMENT_THRESHOLD,
    };
    // Compute stats from actual game data (same source as leaderboard)
    const allGames = db.getGamesByAgent(agent.id);
    const played   = allGames.length;
    const wins   = allGames.filter(g => g.score === 1).length;
    const losses = allGames.filter(g => g.score === 0).length;
    const draws  = allGames.filter(g => g.score === 0.5).length;

    // Rating history from snapshots (one entry per rebuild)
    const snapshots = db.getRatingSnapshots(agent.id);
    const ratingHistory = snapshots.map((snap, i) => ({
      r:     snap.rating,
      ts:    snap.created_at,
      delta: i > 0 ? snap.rating - snapshots[i - 1].rating : 0,
    }));

    const configVersions = db.getConfigVersions(agent.id).map(cv => ({
      hash:         cv.agent_hash,
      harness:      cv.harness,
      model:        cv.model,
      config_files: cv.config_files,
      first_seen_at: cv.first_seen_at,
    }));

    // Build matches: submissions with their game rows
    // Cache challenge baselines for this agent's matches
    const baselineCache = {};
    function getChallengeBaseline(challengeId) {
      if (baselineCache[challengeId] !== undefined) return baselineCache[challengeId];
      const cFile = path.join(__dirname, '..', 'challenges-active', `${challengeId}.json`);
      try {
        const meta = JSON.parse(fs.readFileSync(cFile, 'utf8'));
        baselineCache[challengeId] = {
          baseline_passing: meta.baseline_passing != null ? meta.baseline_passing : null,
          broken_by_bug:    meta.broken_by_bug    != null ? meta.broken_by_bug    : null,
        };
      } catch (_) {
        baselineCache[challengeId] = { baseline_passing: null, broken_by_bug: null };
      }
      return baselineCache[challengeId];
    }

    // Build snapshot delta lookup: for each snapshot timestamp, compute the
    // rating change from the previous snapshot. Used to show per-submission ELO +/-.
    const snapshotDeltas = new Map();
    for (let i = 0; i < snapshots.length; i++) {
      const delta = i > 0 ? snapshots[i].rating - snapshots[i - 1].rating : 0;
      // Multiple snapshots can share a timestamp (from batch rebuilds).
      // Keep the cumulative delta for that timestamp.
      const ts = snapshots[i].created_at;
      snapshotDeltas.set(ts, (snapshotDeltas.get(ts) || 0) + delta);
    }

    // Deduplicate: keep only the best pairwise-eligible submission per challenge.
    const allSubs = db.getSubmissionsByAgent(agent.id);
    const bestByChallenge = {};
    for (const s of allSubs) {
      if (isPairwiseSubmissionExcluded(s)) continue;
      bestByChallenge[s.challenge_id] = pickBetterSubmission(bestByChallenge[s.challenge_id], s);
    }
    const dedupedSubs = Object.values(bestByChallenge);
    const matches = dedupedSubs.map(sub => {
      const bl = getChallengeBaseline(sub.challenge_id);
      const games = db.getGamesBySubmission(sub.id, agent.id).map(g => {
        const oppSub = db.getSubmissionById(g.opponent_submission_id);
        return {
          id:                   g.id,
          opponent_id:          g.opponent_id,
          opponent_model:       g.opponent_model,
          score:                g.score,
          delta:                g.delta,
          rating_after:         g.rating_after,
          opponent_tests_ok:    oppSub ? oppSub.tests_ok    : null,
          opponent_tests_total: oppSub ? oppSub.tests_total : null,
          opponent_time:        oppSub ? oppSub.agent_time_seconds : null,
        };
      });

      // Compute ELO delta from snapshots: find the snapshot at this submission's
      // timestamp and diff against the previous one. This is the rating change
      // caused by this submission triggering a full BT rebuild.
      const subDelta = snapshotDeltas.get(sub.created_at) || 0;

      return {
        submission_id: sub.id,
        run_id:        sub.run_id,
        challenge_id:  sub.challenge_id,
        tests_ok:      sub.tests_ok,
        tests_total:   sub.tests_total,
        tests_passed:  (bl.baseline_passing != null) ? Math.max(0, (sub.tests_ok || 0) - bl.baseline_passing) > 0 : (sub.tests_ok || 0) > 0,
        baseline_passing: bl.baseline_passing,
        broken_by_bug:    bl.broken_by_bug,
        agent_time:    sub.agent_time_seconds,
        diff_lines:    sub.diff_lines,
        exit_code:     sub.exit_code,
        tokens_in:     sub.tokens_in || 0,
        tokens_out:    sub.tokens_out || 0,
        cost_usd:      sub.cost_usd || 0,
        created_at:    sub.created_at,
        games,
        total_delta:   Math.round(subDelta * 100) / 100,
      };
    });

    return json(res, 200, {
      id:             agent.id,
      display_name:   agent.display_name || agent.id,
      rank,
      placement,
      harness:        agent.harness,
      model:          agent.model,
      current_hash:   agent.current_hash,
      elo:            Math.round(agent.rating),
      rd:             Math.round(agent.rd),
      played,
      wins,
      losses,
      draws,
      wr:             allGames.length > 0 ? wins / allGames.length : 0,
      d7:             (() => {
                        const prev = db.getPreviousSnapshots(agent.id,
                          new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString());
                        const base = prev ? prev.rating : (snapshots.length > 0 ? snapshots[0].rating : agent.rating);
                        return Math.round(agent.rating - base);
                      })(),
      ratingHistory,
      configVersions,
      matches,
    });
  }

  // GET /api/games/:id
  const gameMatch = pathname.match(/^\/api\/games\/(\d+)$/);
  if (req.method === 'GET' && gameMatch) {
    const game = db.getGameById(Number(gameMatch[1]));
    if (!game) return json(res, 404, { error: 'Game not found' });

    const sub = db.getSubmissionById(game.submission_id);
    const oppSub = db.getSubmissionById(game.opponent_submission_id);
    const ch = db.getChallenge(game.challenge_id);

    let blPass = null, blBroken = null;
    const chFile = path.join(__dirname, '..', 'challenges-active', `${game.challenge_id}.json`);
    try {
      const meta = JSON.parse(fs.readFileSync(chFile, 'utf8'));
      blPass = meta.baseline_passing != null ? meta.baseline_passing : null;
      blBroken = meta.broken_by_bug != null ? meta.broken_by_bug : null;
    } catch {}

    const formatSub = (s) => s ? {
      id:                 s.id,
      run_id:             s.run_id,
      agent_id:           s.agent_id,
      harness:            s.harness,
      model:              s.model,
      tests_ok:           s.tests_ok,
      tests_total:        s.tests_total,
      tests_failed:       s.tests_failed,
      agent_time_seconds: s.agent_time_seconds,
      test_time_seconds:  s.test_time_seconds,
      diff_lines:         s.diff_lines,
      diff:               stripTestFiles(s.diff || ''),
      exit_code:          s.exit_code,
      tokens_in:          s.tokens_in || 0,
      tokens_out:         s.tokens_out || 0,
      cost_usd:           s.cost_usd || 0,
      created_at:         s.created_at,
    } : null;

    return json(res, 200, {
      id:                game.id,
      challenge_id:      game.challenge_id,
      challenge_title:   ch ? ch.title : game.challenge_id,
      agent_id:          game.agent_id,
      opponent_id:       game.opponent_id,
      score:             game.score,
      delta:             game.delta,
      rating_before:     game.rating_before,
      rating_after:      game.rating_after,
      opponent_rating:   game.opponent_rating,
      opponent_model:    game.opponent_model,
      baseline_passing:  blPass,
      broken_by_bug:     blBroken,
      created_at:        game.created_at,
      submission:        formatSub(sub),
      opponent_submission: formatSub(oppSub),
    });
  }

  // GET /api/compare/:agentA/:agentB
  const compareMatch = pathname.match(/^\/api\/compare\/([^/]+)\/([^/]+)$/);
  if (req.method === 'GET' && compareMatch) {
    const agentA = db.getAgent(decodeURIComponent(compareMatch[1]));
    const agentB = db.getAgent(decodeURIComponent(compareMatch[2]));
    if (!agentA) return json(res, 404, { error: `Agent not found: ${compareMatch[1]}` });
    if (!agentB) return json(res, 404, { error: `Agent not found: ${compareMatch[2]}` });

    const qualified = db.getAllAgents().filter(a => a.challenges_attempted >= PLACEMENT_THRESHOLD);
    const rankOf = (ag) => ((ag.challenges_attempted || 0) >= PLACEMENT_THRESHOLD)
      ? (qualified.findIndex(a => a.id === ag.id) + 1)
      : null;
    const placementOf = (ag) => ((ag.challenges_attempted || 0) >= PLACEMENT_THRESHOLD)
      ? null
      : { attempted: ag.challenges_attempted || 0, required: PLACEMENT_THRESHOLD };
    const rankA = rankOf(agentA);
    const rankB = rankOf(agentB);

    const gamesA = db.getGamesByAgent(agentA.id);
    const gamesB = db.getGamesByAgent(agentB.id);

    const buildStats = (agent, rank, games) => ({
      id:      agent.id,
      display_name: agent.display_name || agent.id,
      harness: agent.harness,
      model:   agent.model,
      elo:     Math.round(agent.rating),
      rank,
      placement: placementOf(agent),
      played:  games.length,
      wins:    games.filter(g => g.score === 1).length,
      losses:  games.filter(g => g.score === 0).length,
      draws:   games.filter(g => g.score === 0.5).length,
      wr:      games.length > 0 ? games.filter(g => g.score === 1).length / games.length : 0,
      avgCost: (() => {
        const subs = db.getSubmissionsByAgent(agent.id);
        const wc = subs.filter(s => s.cost_usd > 0);
        return wc.length > 0 ? wc.reduce((sum, s) => sum + s.cost_usd, 0) / wc.length : null;
      })(),
    });

    // Build per-challenge comparison
    const subsA = db.getSubmissionsByAgent(agentA.id);
    const subsB = db.getSubmissionsByAgent(agentB.id);

    // Best sub per challenge (same logic as agent page)
    const bestA = {}, bestB = {};
    for (const s of subsA) {
      if (isPairwiseSubmissionExcluded(s)) continue;
      bestA[s.challenge_id] = pickBetterSubmission(bestA[s.challenge_id], s);
    }
    for (const s of subsB) {
      if (isPairwiseSubmissionExcluded(s)) continue;
      bestB[s.challenge_id] = pickBetterSubmission(bestB[s.challenge_id], s);
    }

    const allChallengeIds = new Set([...Object.keys(bestA), ...Object.keys(bestB)]);
    const challenges = [];

    for (const cid of allChallengeIds) {
      const ch = db.getChallenge(cid);
      let blPass = null, blBroken = null;
      const chFile = path.join(__dirname, '..', 'challenges-active', `${cid}.json`);
      try {
        const meta = JSON.parse(fs.readFileSync(chFile, 'utf8'));
        blPass = meta.baseline_passing != null ? meta.baseline_passing : null;
        blBroken = meta.broken_by_bug != null ? meta.broken_by_bug : null;
      } catch {}

      const fmtSub = (s) => s ? {
        submission_id: s.id,
        tests_ok:      s.tests_ok,
        tests_total:   s.tests_total,
        agent_time:    s.agent_time_seconds,
        diff_lines:    s.diff_lines,
        cost_usd:      s.cost_usd || 0,
        tests_fixed:   blPass != null ? Math.max(0, (s.tests_ok || 0) - blPass) : (s.tests_ok || 0),
      } : null;

      // Find the game between these two agents on this challenge
      let game = null;
      if (bestA[cid] && bestB[cid]) {
        const gRow = db.getGamesBySubmission(bestA[cid].id, agentA.id)
          .find(g => g.opponent_id === agentB.id);
        if (gRow) {
          game = { id: gRow.id, score: gRow.score, delta: gRow.delta };
        }
      }

      challenges.push({
        challenge_id: cid,
        title: ch ? ch.title : cid,
        baseline_passing: blPass,
        broken_by_bug: blBroken,
        a: fmtSub(bestA[cid]),
        b: fmtSub(bestB[cid]),
        game,
      });
    }

    // Sort: both submitted first, then by challenge_id
    challenges.sort((x, y) => {
      const bothX = x.a && x.b ? 1 : 0;
      const bothY = y.a && y.b ? 1 : 0;
      if (bothX !== bothY) return bothY - bothX;
      return x.challenge_id.localeCompare(y.challenge_id);
    });

    // Head-to-head record (only challenges where both competed)
    const h2h = { a_wins: 0, b_wins: 0, draws: 0 };
    for (const c of challenges) {
      if (!c.game) continue;
      if (c.game.score === 1) h2h.a_wins++;
      else if (c.game.score === 0) h2h.b_wins++;
      else h2h.draws++;
    }

    return json(res, 200, {
      a: buildStats(agentA, rankA, gamesA),
      b: buildStats(agentB, rankB, gamesB),
      h2h,
      challenges,
    });
  }

  return json(res, 404, { error: 'Not found' });
}

// ── importChallenges ──────────────────────────────────────────────────────────

function importChallenges() {
  const challengesDir = ACTIVE_DIR;
  if (!fs.existsSync(challengesDir)) return;
  const files = fs.readdirSync(challengesDir).filter(f => f.endsWith('.json'));
  let imported = 0;
  for (const f of files) {
    const id = f.replace('.json', '');
    const existing = db.getChallenge(id);
    if (existing && existing.repo) continue;
    try {
      const meta = JSON.parse(fs.readFileSync(path.join(challengesDir, f), 'utf8'));
      const fixDiff = meta.fixDiff || '';
      const diffLines = fixDiff.split('\n').filter(l => /^[+-]/.test(l) && !/^[+-]{3}/.test(l)).length;
      db.upsertChallenge({
        id,
        repo:        meta.repoUrl || meta.repo || '',
        title:       meta.issue?.title || meta.title || id,
        difficulty:  { filesChanged: 0, linesAdded: diffLines },
        testCommand: meta.testCommand,
        fixCommit:   meta.fixCommit,
      });
      imported++;
    } catch (_) {}
  }
  if (imported > 0) console.log(`[agentelo-api] imported ${imported} challenges from disk`);
}

// ── server ────────────────────────────────────────────────────────────────────

importChallenges();

const server = http.createServer((req, res) => {
  const startTs = Date.now();

  handleRequest(req, res).catch(err => {
    console.error('[api] unhandled error:', err);
    req._logErr = err.message;
    try { json(res, 500, { error: 'Internal server error' }); } catch (_) {}
  }).finally(() => {
    try {
      const url = new URL(req.url, `http://localhost:${PORT}`);
      let logPath = url.pathname;
      if (url.searchParams.has('api_key')) {
        const p = new URLSearchParams(url.searchParams);
        p.set('api_key', '[redacted]');
        logPath += '?' + p.toString();
      } else if (url.search) {
        logPath += url.search;
      }
      const entry = {
        ts: new Date().toISOString(),
        method: req.method,
        path: logPath,
        status: res.statusCode,
        duration_ms: Date.now() - startTs,
        ip: getClientIp(req),
        ua: req.headers['user-agent'] || null,
      };
      if (req._logAgentId) entry.agent_id = req._logAgentId;
      if (req._logErr) entry.err = req._logErr;
      process.stdout.write(JSON.stringify(entry) + '\n');
    } catch (_) {}
  });
});

server.listen(PORT, () => {
  console.log(`[agentelo-api] listening on http://localhost:${PORT}`);
  if (VERIFICATION_ENABLED) {
    verificationWorker().catch(err => console.error('[verify] worker crashed:', err));
  } else {
    console.log('[agentelo-api] VERIFICATION_ENABLED=false — submissions verified immediately');
  }
});
