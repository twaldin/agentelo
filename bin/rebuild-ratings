#!/usr/bin/env node
'use strict';

const fs = require('fs');
const path = require('path');
const db = require('../core/db');
const { updateRating } = require('../core/glicko2');

const CHALLENGES_DIR = path.resolve(__dirname, '..', 'challenges');

// Load baseline data from challenge JSON files
const baselineCache = {};
function getBaseline(challengeId) {
  if (baselineCache[challengeId] !== undefined) return baselineCache[challengeId];
  try {
    const meta = JSON.parse(fs.readFileSync(path.join(CHALLENGES_DIR, `${challengeId}.json`), 'utf8'));
    baselineCache[challengeId] = {
      baseline_passing: meta.baseline_passing != null ? meta.baseline_passing : null,
      broken_by_bug: meta.broken_by_bug != null ? meta.broken_by_bug : null,
    };
  } catch {
    baselineCache[challengeId] = { baseline_passing: null, broken_by_bug: null };
  }
  return baselineCache[challengeId];
}

console.log('[rebuild] Starting full pairwise rating rebuild...');

// 1. Clear all games and reset all agent ratings
db.getDb().exec('DELETE FROM games');
const agents = db.getAllAgents();
for (const agent of agents) {
  db.updateAgent({
    id: agent.id, rating: 1500, rd: 350, volatility: 0.06,
    wins: 0, challenges_attempted: 0, current_hash: agent.current_hash,
  });
}
console.log(`[rebuild] Reset ${agents.length} agents to 1500 ELO`);

// 2. Get all submissions grouped by challenge, ordered by time
const allSubs = db.getDb().prepare('SELECT * FROM submissions ORDER BY created_at ASC').all();
const byChallenge = {};
for (const s of allSubs) {
  if (!byChallenge[s.challenge_id]) byChallenge[s.challenge_id] = [];
  byChallenge[s.challenge_id].push(s);
}

// Helper: compute score between two submissions
// Uses tests_fixed (tests_ok - baseline_passing) NOT raw tests_ok.
// When both agents fixed 0 tests, it's a draw — no ELO for "failing faster".
function computeScore(a, b, challengeId) {
  const bl = getBaseline(challengeId);
  const base = (bl.baseline_passing != null) ? bl.baseline_passing : 0;
  // No clamp — negative means agent made things worse, which should lose to 0
  const aFixed = (a.tests_ok || 0) - base;
  const bFixed = (b.tests_ok || 0) - base;

  if (aFixed > bFixed) return 1;
  if (aFixed < bFixed) return 0;

  // Both fixed the same number — tiebreak ONLY when both solved ALL broken tests
  if (aFixed <= 0 && bFixed <= 0) return 0.5;

  const broken = (bl.broken_by_bug != null) ? bl.broken_by_bug : 0;
  const bothPerfect = broken > 0 && aFixed >= broken && bFixed >= broken;
  if (!bothPerfect) return 0.5; // same partial fix = draw

  // Both solved all — cheaper wins (cost tiebreak), fall back to faster
  const aCost = a.cost_usd || 0;
  const bCost = b.cost_usd || 0;
  if (aCost > 0 && bCost > 0) {
    if (aCost < bCost) return 1;
    if (aCost > bCost) return 0;
    return 0.5;
  }
  if ((a.agent_time_seconds||0) < (b.agent_time_seconds||0)) return 1;
  if ((a.agent_time_seconds||0) > (b.agent_time_seconds||0)) return 0;
  return 0.5;
}

let totalGames = 0;

// 3. For each challenge, do full pairwise: every agent plays every other agent once
for (const [challengeId, subs] of Object.entries(byChallenge)) {
  // Mark all agents as having attempted this challenge
  for (const sub of subs) {
    const a = db.getAgent(sub.agent_id);
    if (a) db.updateAgent({ ...a, challenges_attempted: a.challenges_attempted + 1 });
  }

  // Full pairwise: for each pair (i, j) where i < j, agent i plays agent j
  for (let i = 0; i < subs.length; i++) {
    for (let j = i + 1; j < subs.length; j++) {
      const subA = subs[i], subB = subs[j];
      const agentA = db.getAgent(subA.agent_id);
      const agentB = db.getAgent(subB.agent_id);
      if (!agentA || !agentB) continue;

      const scoreA = computeScore(subA, subB, challengeId);
      const scoreB = scoreA === 1 ? 0 : scoreA === 0 ? 1 : 0.5;

      // Update A
      const newA = updateRating(
        { rating: agentA.rating, rd: agentA.rd, volatility: agentA.volatility },
        [{ opponentRating: agentB.rating, opponentRd: agentB.rd, score: scoreA }]
      );
      const deltaA = newA.rating - agentA.rating;
      db.insertGame({
        challenge_id: challengeId, agent_id: subA.agent_id, opponent_id: subB.agent_id,
        submission_id: subA.id, opponent_submission_id: subB.id,
        score: scoreA, rating_before: agentA.rating, rating_after: newA.rating,
        rd_before: agentA.rd, rd_after: newA.rd, delta: Math.round(deltaA * 10) / 10,
        opponent_rating: agentB.rating, opponent_rd: agentB.rd, opponent_model: agentB.model,
      });
      db.updateAgent({ id: agentA.id, rating: newA.rating, rd: newA.rd, volatility: newA.volatility,
        wins: agentA.wins + (scoreA === 1 ? 1 : 0), challenges_attempted: agentA.challenges_attempted,
        current_hash: agentA.current_hash });

      // Update B
      const freshB = db.getAgent(subB.agent_id); // re-read in case B was also updated
      const newB = updateRating(
        { rating: freshB.rating, rd: freshB.rd, volatility: freshB.volatility },
        [{ opponentRating: newA.rating, opponentRd: newA.rd, score: scoreB }]
      );
      const deltaB = newB.rating - freshB.rating;
      db.insertGame({
        challenge_id: challengeId, agent_id: subB.agent_id, opponent_id: subA.agent_id,
        submission_id: subB.id, opponent_submission_id: subA.id,
        score: scoreB, rating_before: freshB.rating, rating_after: newB.rating,
        rd_before: freshB.rd, rd_after: newB.rd, delta: Math.round(deltaB * 10) / 10,
        opponent_rating: newA.rating, opponent_rd: newA.rd, opponent_model: agentA.model,
      });
      db.updateAgent({ id: freshB.id, rating: newB.rating, rd: newB.rd, volatility: newB.volatility,
        wins: freshB.wins + (scoreB === 1 ? 1 : 0), challenges_attempted: freshB.challenges_attempted,
        current_hash: freshB.current_hash });

      totalGames += 2;
    }
  }
}

console.log(`[rebuild] Done. ${totalGames} games from ${allSubs.length} submissions.`);
const final = db.getAllAgents().filter(a => a.challenges_attempted > 0).sort((a, b) => b.rating - a.rating);
console.log('\n--- REBUILT LEADERBOARD ---');
final.forEach((a, i) => {
  console.log(`#${i+1} ${a.id.padEnd(40)} ELO: ${Math.round(a.rating).toString().padStart(5)}  W: ${String(a.wins).padStart(2)}  CH: ${a.challenges_attempted}`);
});
