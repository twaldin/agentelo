#!/usr/bin/env node
'use strict';

// Validate new challenges and report which are ready for seeding.
// Checks: baseline > 0, broken >= 1, test runner works, fix diff exists,
// challenge is solvable (fix actually fixes the tests).
//
// Usage:
//   node bin/validate-challenges              # validate all unvalidated
//   node bin/validate-challenges --promote    # also copy validated to active pool
//   node bin/validate-challenges --list       # just list status

const fs = require('fs');
const path = require('path');
const { spawnSync, execSync } = require('child_process');
const os = require('os');

const CHALLENGES_DIR = path.resolve(__dirname, '..', 'challenges');
const VALIDATED_DIR = path.resolve(__dirname, '..', 'challenges-validated');
const PENDING_DIR = path.resolve(__dirname, '..', 'challenges-pending');
const CACHE_DIR = path.resolve(__dirname, '..', '.cache', 'repos');

const args = process.argv.slice(2);
const PROMOTE = args.includes('--promote');
const LIST_ONLY = args.includes('--list');

function slugify(str) {
  return str.replace(/[\/\\.:\s]+/g, '-').replace(/[^a-zA-Z0-9-]/g, '').toLowerCase();
}

function detectLang(challenge) {
  const cmd = challenge.testCommand || '';
  if (cmd.includes('pytest') || cmd.includes('python')) return 'python';
  if (cmd.includes('go test')) return 'go';
  if (cmd.includes('cargo test')) return 'rust';
  return 'javascript';
}

const challenges = fs.readdirSync(CHALLENGES_DIR)
  .filter(f => f.endsWith('.json'))
  .map(f => {
    const data = JSON.parse(fs.readFileSync(path.join(CHALLENGES_DIR, f), 'utf8'));
    return { file: f, ...data };
  })
  .sort((a, b) => a.id.localeCompare(b.id));

console.log(`Validating ${challenges.length} challenges\n`);

const results = { valid: [], invalid: [], warning: [] };

for (const ch of challenges) {
  const issues = [];
  const warnings = [];

  // Basic checks
  if (!ch.baseline_passing || ch.baseline_passing <= 0) issues.push('baseline=0 (test runner broken)');
  if (!ch.broken_by_bug || ch.broken_by_bug <= 0) issues.push('broken=0 (no failing tests)');
  if (!ch.fixDiff || ch.fixDiff.trim() === '') issues.push('no fixDiff');
  if (!ch.buggyCommit && !ch.commit) issues.push('no buggy commit');
  if (!ch.testCommand) issues.push('no test command');

  // Size checks
  if (ch.broken_by_bug > 100) warnings.push(`broken=${ch.broken_by_bug} (very high)`);
  if (ch.baseline_passing > 10000) warnings.push(`baseline=${ch.baseline_passing} (huge test suite, slow)`);

  // Fix diff should have code changes (not just tests)
  if (ch.fixDiff) {
    const codeLines = ch.fixDiff.split('\n').filter(l =>
      (l.startsWith('+') || l.startsWith('-')) &&
      !l.startsWith('+++') && !l.startsWith('---') &&
      !/\/test[s]?\//i.test(l) && !/test_/i.test(l) && !/_test\./i.test(l)
    ).length;
    if (codeLines === 0) issues.push('fix is test-only (no code changes)');
    if (codeLines > 500) warnings.push(`large fix (${codeLines} code lines)`);
  }

  const lang = detectLang(ch);
  const status = issues.length === 0 ? 'VALID' : 'INVALID';

  if (status === 'VALID') {
    results.valid.push(ch);
  } else {
    results.invalid.push({ ch, issues });
  }
  if (warnings.length > 0) results.warning.push({ ch, warnings });

  const icon = status === 'VALID' ? '✓' : '✗';
  const extra = issues.length > 0 ? ` — ${issues.join(', ')}` : '';
  const warn = warnings.length > 0 ? ` ⚠ ${warnings.join(', ')}` : '';
  console.log(`  ${icon} ${ch.id} [${lang}] bl=${ch.baseline_passing} broke=${ch.broken_by_bug}${extra}${warn}`);
}

console.log(`\n--- Summary ---`);
console.log(`Valid: ${results.valid.length}`);
console.log(`Invalid: ${results.invalid.length}`);
console.log(`Warnings: ${results.warning.length}`);

if (PROMOTE && results.valid.length > 0) {
  console.log(`\nPromoting ${results.valid.length} valid challenges to active pool...`);
  // They're already in challenges/ — just report
  for (const ch of results.valid) {
    console.log(`  ✓ ${ch.id}`);
  }
}

// Output as JSON for automated consumption
const outFile = path.resolve(__dirname, '..', 'challenge-validation.json');
fs.writeFileSync(outFile, JSON.stringify({
  timestamp: new Date().toISOString(),
  total: challenges.length,
  valid: results.valid.map(c => c.id),
  invalid: results.invalid.map(r => ({ id: r.ch.id, issues: r.issues })),
  warnings: results.warning.map(r => ({ id: r.ch.id, warnings: r.warnings })),
}, null, 2));
console.log(`\nReport saved to ${outFile}`);
