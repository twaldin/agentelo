// === CLAUDE-PRIORITY: all 3 Claude + OR (no Spark, save GPT quota) ===
const MODELS_CLAUDE = [
  { harness: 'claude-code', model: 'claude-haiku-4-5-20251001' },
  { harness: 'claude-code', model: 'claude-sonnet-4-6' },
  { harness: 'claude-code', model: 'claude-opus-4-6' },
  // OR paid (separate billing)
  { harness: 'opencode', model: 'openrouter/minimax/minimax-m2.5' },
  { harness: 'opencode', model: 'openrouter/mistralai/devstral-small-2507' },
  { harness: 'opencode', model: 'openrouter/moonshotai/kimi-k2.5' },
  { harness: 'opencode', model: 'openrouter/openai/gpt-oss-120b:free' },
  { harness: 'opencode', model: 'openrouter/z-ai/glm-4.5-air:free' },
];

// === MINIMAL: only Claude (light) + Gemini Flash (no OR, no Spark) ===
const MODELS_MINIMAL = [
  { harness: 'claude-code', model: 'claude-haiku-4-5-20251001' },
  { harness: 'gemini', model: 'gemini-2.5-flash' },
];

const MODELS = PHASE === 'test' ? MODELS_PHASE1 : PHASE === 'proven' ? MODELS_PROVEN : PHASE === 'budget' ? MODELS_BUDGET : PHASE === 'claude' ? MODELS_CLAUDE : PHASE === 'minimal' ? MODELS_MINIMAL : MODELS_ALL;

// --- Challenge loading ---
const challenges = fs.readdirSync(CHALLENGES_DIR)
  .filter(f => f.endsWith('.json'))
  .map(f => f.replace('.json', ''))
  .sort((a, b) => {
    // Priority: small repos first (faster tests)
    const priority = { 'qs': 0, 'koa': 1, 'fastify': 2, 'path': 2, 'node-fetch': 2, 'svelte': 3 };
    const aP = Object.entries(priority).find(([k]) => a.startsWith(k))?.[1] ?? 4;
    const bP = Object.entries(priority).find(([k]) => b.startsWith(k))?.[1] ?? 4;
    return aP - bP;
  });

console.log(`AgentElo Seed Batch — Phase: ${PHASE}`);
console.log(`${challenges.length} challenges × ${MODELS.length} models`);
console.log(`Concurrency: ${MAX_CONCURRENT}`);

// --- Build jobs (round-robin: for each challenge, run all models) ---
function buildJobs() {
  const jobs = [];
  for (const c of challenges) {
    const cFile = path.join(CHALLENGES_DIR, `${c}.json`);
    try {
      const cData = JSON.parse(fs.readFileSync(cFile, 'utf8'));
      if (!cData.testCommand) { console.log(`Skip ${c} — no test command`); continue; }
    } catch { continue; }

    for (const m of MODELS) {
      // Skip if result already exists for this challenge+model
      try {
        const existing = fs.readdirSync(RESULTS_DIR).filter(f =>
          f.startsWith(`${c}-`) && f.endsWith('.json')
        );
        const hasResult = existing.some(f => {
          try {
            const r = JSON.parse(fs.readFileSync(path.join(RESULTS_DIR, f), 'utf8'));
            return r.model === m.model;
          } catch { return false; }
        });
        if (hasResult) continue;
      } catch {}

      jobs.push({ ...m, challenge: c, local: false });
    }
  }
  return jobs;
}

// --- Anomaly detection ---
const anomalies = [];

function checkAnomaly(job, output, resultFile) {
  const issues = [];

  // Check result file
  let result;
  try { result = JSON.parse(fs.readFileSync(resultFile, 'utf8')); } catch { return; }

  // 0/0 tests — parser failed or tests didn't run
  if (result.tests_ok === 0 && result.tests_total === 0) {
    issues.push('0/0 tests — parser or test runner failure');
  }

  // 0/N tests — agent produced nothing useful
  if (result.tests_ok === 0 && result.tests_total > 0) {
    issues.push(`0/${result.tests_total} tests — agent may have broken everything`);
  }

  // <60s solve — suspiciously fast (likely errored out)
  if (result.agent_time_seconds < 60 && result.tests_ok > 0) {
    issues.push(`${Math.round(result.agent_time_seconds)}s solve — suspiciously fast`);
  }

  // Tampered files
  if (result.tampered) {
    issues.push(`tampered: ${(result.tampered_files || []).join(', ')}`);
  }

  if (issues.length > 0) {
    const entry = `[${new Date().toISOString()}] ${job.challenge} × ${job.model}: ${issues.join('; ')}`;
    anomalies.push(entry);
    console.log(`  ⚠ ANOMALY: ${issues.join('; ')}`);
    fs.appendFileSync(ANOMALY_LOG, entry + '\n');
  }
}

// --- Junk detection: 0-diff + <60s = rate limit or crash, not a real attempt ---
const JUNK_THRESHOLD = 3; // after N junk results, skip remaining jobs for this model
const junkCounts = {}; // model -> count
const skippedModels = new Set();

function isJunkResult(resultFile) {
  try {
    const r = JSON.parse(fs.readFileSync(resultFile, 'utf8'));
    // Junk = no diff at all
    if ((r.diff_lines || 0) === 0) return true;
    // Also check for rate-limited runs — agent log contains rate limit message
    // but still produced a diff (from retry against wrong state)
    const logFile = r.log_file || resultFile.replace('.json', '.log');
    if (fs.existsSync(logFile)) {
      const logStart = fs.readFileSync(logFile, 'utf8').slice(0, 500);
      if (/hit your (usage )?limit|rate.?limit|resets \d+am|exhausted your capacity|RESOURCE_EXHAUSTED/i.test(logStart)) {
        console.log(`  ⚠ Rate-limited run detected — treating as junk`);
        return true;
      }
    }
    return false;
  } catch { return false; }
}

function purgeJunkResult(resultFile, job) {
  const model = job.model;
  junkCounts[model] = (junkCounts[model] || 0) + 1;

  // Delete the result file so seed-batch doesn't skip this job on restart
  try { fs.unlinkSync(resultFile); } catch {}

  // Delete submission from DB (agentelo CLI already submitted it)
  try {
    const db = require('../core/db');
    const subs = db.getSubmissionsByChallenge(job.challenge)
      .filter(s => s.model === model && s.diff_lines === 0 && s.agent_time_seconds < 60);
    for (const s of subs) {
      db.getDb().prepare('DELETE FROM games WHERE submission_id = ? OR opponent_submission_id = ?').run(s.id, s.id);
      db.getDb().prepare('DELETE FROM submissions WHERE id = ?').run(s.id);
    }
  } catch (e) { console.error(`  [junk] DB cleanup failed: ${e.message}`); }

  const entry = `[${new Date().toISOString()}] JUNK: ${job.challenge} × ${model} — 0 diff, <60s (${junkCounts[model]}/${JUNK_THRESHOLD})`;
  console.log(`  🗑 ${entry}`);
  fs.appendFileSync(ANOMALY_LOG, entry + '\n');

  if (junkCounts[model] >= JUNK_THRESHOLD) {
    skippedModels.add(model);
    const skip = `[${new Date().toISOString()}] SKIPPED: ${model} — ${JUNK_THRESHOLD} junk results, skipping remaining jobs`;
    console.log(`  ⛔ ${skip}`);
    fs.appendFileSync(ANOMALY_LOG, skip + '\n');
  }

  // Rebuild ratings to undo live scoring damage from the purged submission
  try {
    const { execSync } = require('child_process');
    execSync('node ' + path.resolve(__dirname, 'rebuild-ratings'), { stdio: 'pipe', timeout: 30000 });
  } catch {}
}

// --- Job runner ---
let passed = 0, failed = 0, errored = 0, totalJobs = 0, completedJobs = 0;

// Claude rate limiter: only 1 Claude model running at a time (shared subscription)
let claudeLock = false;
const claudeQueue = [];
function acquireClaude() {
  if (!claudeLock) { claudeLock = true; return Promise.resolve(); }
  return new Promise(resolve => claudeQueue.push(resolve));
}
function releaseClaude() {
  if (claudeQueue.length > 0) { claudeQueue.shift()(); }
  else { claudeLock = false; }
}
function isClaudeModel(model) {
  return model.startsWith('claude-');
}

function spawnJob(job) {
  // Skip models that have been flagged as junk producers
  if (skippedModels.has(job.model)) {
    completedJobs++;
    return Promise.resolve();
  }

  const agentId = slugify(job.harness + '-' + job.model);
  const seedKeys = loadSeedKeys();
  const apiKey = seedKeys[agentId] || '';

  completedJobs++;
  const jobNum = completedJobs;
  console.log(`[${jobNum}/${totalJobs}] ${job.challenge} × ${job.model}`);

  const childLogFile = path.join(RESULTS_DIR, `seed-${job.challenge}-${job.model.replace(/\//g, '-')}.log`);
  const childLogStream = fs.createWriteStream(childLogFile);

  const isClaude = isClaudeModel(job.model);
  const run = async () => {
    if (isClaude) await acquireClaude();

    const child = spawn('node', [AGENTELO, 'seed', '--harness', job.harness, '--model', job.model, '--challenge', job.challenge], {
      stdio: ['ignore', 'pipe', 'pipe'],
      env: { ...process.env, AGENTELO_KEY: apiKey },
    });

    let output = '';
    child.stdout.on('data', d => { output += d; childLogStream.write(d); });
    child.stderr.on('data', d => { output += d; childLogStream.write(d); });

    return new Promise((resolve) => {
      child.on('close', (code) => {
        childLogStream.end();
        if (isClaude) releaseClaude();

      // Find result file
      const resultMatch = output.match(/Result saved: (.+\.json)/);
      const resultFile = resultMatch ? path.resolve(__dirname, '..', resultMatch[1]) : null;

      // Parse tests_ok from output
      const fixedMatch = output.match(/Tests fixed: (\d+)\/(\d+)/);
      const testsOkMatch = output.match(/tests_ok=(\d+)/);

      if (code === 0 && fixedMatch) {
        const [, fixed, broken] = fixedMatch;
        const color = parseInt(fixed) >= parseInt(broken) ? '✓' : '◐';
        console.log(`  ${color} ${job.challenge} × ${job.model} — ${fixed}/${broken} fixed`);
        if (parseInt(fixed) >= parseInt(broken)) passed++; else failed++;
      } else if (code === 0) {
        failed++;
        console.log(`  ✗ ${job.challenge} × ${job.model} — completed, check result`);
      } else {
        errored++;
        const lines = output.split('\n').filter(l => l.includes('Error') || l.includes('error'));
        const hint = lines.length > 0 ? ` (${lines[lines.length - 1].trim().slice(0, 80)})` : '';
        console.log(`  ✗ ${job.challenge} × ${job.model} — error (exit ${code})${hint}`);
      }

      // Anomaly detection
      if (resultFile && fs.existsSync(resultFile)) {
        checkAnomaly(job, output, resultFile);

        // Junk detection: 0-diff + <60s = rate limit or crash, purge it
        if (isJunkResult(resultFile)) {
          purgeJunkResult(resultFile, job);
        }
      }

      resolve();
    });
  });
  };
  return run();
}

function runJobQueue(jobs, concurrency) {
  if (jobs.length === 0) return Promise.resolve();
  return new Promise((resolve) => {
    let idx = 0, running = 0;
    function next() {
      if (idx >= jobs.length && running === 0) { resolve(); return; }
      while (running < concurrency && idx < jobs.length) {
        running++;
        const job = jobs[idx++];
        spawnJob(job).then(() => { running--; next(); });
      }
    }
    next();
  });
}

// --- Main ---
try { fs.mkdirSync(RESULTS_DIR, { recursive: true }); } catch {}

let jobs = buildJobs();
totalJobs = jobs.length;

console.log(`${totalJobs} jobs remaining (skipping existing results)`);

// Hot reload: after finishing current batch, check for new challenges
async function runWithHotReload() {
  while (true) {
    if (jobs.length === 0) {
      // Check for new challenges
      console.log('\nChecking for new challenges...');
      jobs = buildJobs();
      totalJobs += jobs.length;
      if (jobs.length === 0) {
        console.log('No new jobs. Waiting 60s before next check...');
        await new Promise(r => setTimeout(r, 60000));
        continue;
      }
      console.log(`Hot-reloaded ${jobs.length} new jobs from challenges-active/`);
    }
    await runJobQueue(jobs, MAX_CONCURRENT);
    jobs = []; // clear completed batch, will check for new in next iteration
  }
}

(async () => {
  await runWithHotReload();
  console.log(`\nDone. Passed: ${passed}, Failed: ${failed}, Errored: ${errored}`);
  if (skippedModels.size > 0) {
    console.log(`\n⛔ Skipped models (${JUNK_THRESHOLD}+ junk results — 0 diff, <60s):`);
    for (const m of skippedModels) console.log(`  - ${m} (${junkCounts[m]} junk)`);
  }
  if (anomalies.length > 0) {
    console.log(`\n⚠ ${anomalies.length} anomalies detected — check ${ANOMALY_LOG}`);
  }
  // Check for models that completed all challenges but have submissions with no cost data
  // Re-run those to get real token/cost numbers
  console.log('\nChecking for cost-data backfill...');
  try {
    const totalChallenges = fs.readdirSync(CHALLENGES_DIR).filter(f => f.endsWith('.json')).length;
    const agentSubs = {};
    const allSubs = db.getDb().prepare('SELECT agent_id, challenge_id, cost_usd, id, run_id FROM submissions').all();
    for (const s of allSubs) {
      if (!agentSubs[s.agent_id]) agentSubs[s.agent_id] = [];
      agentSubs[s.agent_id].push(s);
    }
    for (const [agentId, subs] of Object.entries(agentSubs)) {
      const uniqueChallenges = new Set(subs.map(s => s.challenge_id)).size;
      if (uniqueChallenges < totalChallenges) continue; // not done with all challenges yet
      const noCost = subs.filter(s => !s.cost_usd || s.cost_usd === 0);
      if (noCost.length === 0) continue;
      // Find the model config for this agent
      const modelConfig = MODELS.find(m => agentId.includes(m.model.replace(/[\/.:]/g, '-')));
      if (!modelConfig) continue;
      console.log(`  ${agentId}: ${noCost.length}/${subs.length} subs missing cost data — re-seeding for cost`);
      for (const s of noCost) {
        // Delete old result file and DB entry so buildJobs picks it up
        const resultFiles = fs.readdirSync(RESULTS_DIR).filter(f => f.includes(s.challenge_id) && f.includes(modelConfig.model.replace(/[\/.:]/g, '-')) && f.endsWith('.json'));
        for (const rf of resultFiles) {
          try { fs.unlinkSync(path.join(RESULTS_DIR, rf)); } catch {}
        }
        db.getDb().prepare('DELETE FROM games WHERE submission_id = ? OR opponent_submission_id = ?').run(s.id, s.id);
        db.getDb().prepare('DELETE FROM submissions WHERE id = ?').run(s.id);
      }
      console.log(`    Cleared ${noCost.length} submissions for re-seeding`);
    }
  } catch (e) { console.error('Cost backfill check failed:', e.message); }

  // Rebuild ratings from scratch — live incremental scoring can diverge
  console.log('\nRebuilding ratings...');
  try {
    const { execSync } = require('child_process');
    const out = execSync('node ' + path.resolve(__dirname, 'rebuild-ratings'), { encoding: 'utf8', timeout: 60000 });
    const lb = out.split('--- REBUILT LEADERBOARD ---')[1] || '';
    console.log('--- REBUILT LEADERBOARD ---' + lb);
  } catch (e) { console.error('Rebuild failed:', e.message); }
})();

