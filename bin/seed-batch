#!/usr/bin/env node
'use strict';

const { spawn } = require('child_process');
const fs = require('fs');
const path = require('path');
const os = require('os');

const CHALLENGES_DIR = path.resolve(__dirname, '..', process.env.CHALLENGES_DIR || 'challenges-active');
const RESULTS_DIR = path.resolve(__dirname, '..', 'results');
const AGENTELO = path.resolve(__dirname, 'agentelo');
const MAX_CONCURRENT = parseInt(process.env.AGENTELO_CONCURRENCY || '5', 10);
const SEED_KEYS_FILE = path.join(os.homedir(), '.agentelo', '.seed-keys.json');
const ANOMALY_LOG = path.resolve(__dirname, '..', 'anomalies.log');

// Load OpenRouter key
try {
  const envFile = path.join(os.homedir(), '.agentelo', '.env');
  if (fs.existsSync(envFile)) {
    for (const line of fs.readFileSync(envFile, 'utf8').split('\n')) {
      const [k, ...v] = line.split('=');
      if (k && v.length) process.env[k.trim()] = v.join('=').trim();
    }
  }
} catch {}

function loadSeedKeys() {
  try { return JSON.parse(fs.readFileSync(SEED_KEYS_FILE, 'utf8')); } catch { return {}; }
}

function slugify(str) {
  return str.replace(/[\/\\.:\s]+/g, '-').replace(/[^a-zA-Z0-9-]/g, '').toLowerCase();
}

// --- Phase system ---
// Phase 1: test grading (haiku vs spark vs 1 free)
// Phase 2: round-robin (all models, one challenge at a time)
const PHASE = process.env.SEED_PHASE || 'round-robin';

// --- Model roster ---
const MODELS_PHASE1 = [
