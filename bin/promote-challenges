#!/usr/bin/env node
'use strict';

// Scan challenges-pending/ for new challenges, validate them, and promote
// valid ones to challenges-active/ where seed-batch will pick them up.
//
// Runs as a watcher (--watch) or one-shot.
// Usage:
//   node bin/promote-challenges           # one-shot scan
//   node bin/promote-challenges --watch   # continuous watcher (poll every 30s)

const fs = require('fs');
const path = require('path');

const PENDING_DIR = path.resolve(__dirname, '..', 'challenges-pending');
const ACTIVE_DIR = path.resolve(__dirname, '..', 'challenges-active');
const REJECTED_DIR = path.resolve(__dirname, '..', 'challenges-rejected');
const WATCH = process.argv.includes('--watch');
const POLL_INTERVAL = 30000;

fs.mkdirSync(PENDING_DIR, { recursive: true });
fs.mkdirSync(ACTIVE_DIR, { recursive: true });
fs.mkdirSync(REJECTED_DIR, { recursive: true });

function validate(ch) {
  const issues = [];

  if (!ch.baseline_passing || ch.baseline_passing <= 0) issues.push('baseline=0');
  if (!ch.broken_by_bug || ch.broken_by_bug <= 0) issues.push('broken=0');
  if (!ch.fixDiff || ch.fixDiff.trim() === '') issues.push('no fixDiff');
  if (!ch.buggyCommit && !ch.commit) issues.push('no buggy commit');
  if (!ch.testCommand) issues.push('no test command');
  if (ch.broken_by_bug > 200) issues.push(`broken=${ch.broken_by_bug} (too high)`);
  if (ch.baseline_passing > 10000) issues.push(`baseline=${ch.baseline_passing} (huge, slow)`);

  // Fix diff should have code changes, not just tests
  if (ch.fixDiff) {
    const lines = ch.fixDiff.split('\n');
    const codeLines = lines.filter(l =>
      (l.startsWith('+') || l.startsWith('-')) &&
      !l.startsWith('+++') && !l.startsWith('---') &&
      !/\/test[s]?\//i.test(l) && !/test_/i.test(l) && !/_test\./i.test(l)
    ).length;
    if (codeLines === 0) issues.push('fix is test-only');
    if (codeLines > 1000) issues.push(`fix too large (${codeLines} lines)`);
  }

  return issues;
}

function scan() {
  const pending = fs.readdirSync(PENDING_DIR).filter(f => f.endsWith('.json'));
  if (pending.length === 0) return;

  let promoted = 0, rejected = 0;
  for (const file of pending) {
    const srcPath = path.join(PENDING_DIR, file);
    let ch;
    try {
      ch = JSON.parse(fs.readFileSync(srcPath, 'utf8'));
    } catch (err) {
      console.log(`  ✗ ${file}: parse error — ${err.message}`);
      fs.renameSync(srcPath, path.join(REJECTED_DIR, file));
      rejected++;
      continue;
    }

    // Skip if already in active
    if (fs.existsSync(path.join(ACTIVE_DIR, file))) {
      fs.unlinkSync(srcPath); // remove from pending
      continue;
    }

    const issues = validate(ch);
    if (issues.length === 0) {
      fs.copyFileSync(srcPath, path.join(ACTIVE_DIR, file));
      fs.unlinkSync(srcPath);
      console.log(`  ✓ PROMOTED ${ch.id} [bl=${ch.baseline_passing}, broke=${ch.broken_by_bug}]`);
      promoted++;
    } else {
      fs.renameSync(srcPath, path.join(REJECTED_DIR, file));
      console.log(`  ✗ REJECTED ${ch.id}: ${issues.join(', ')}`);
      rejected++;
    }
  }

  if (promoted > 0 || rejected > 0) {
    const total = fs.readdirSync(ACTIVE_DIR).filter(f => f.endsWith('.json')).length;
    console.log(`  ${promoted} promoted, ${rejected} rejected. Active pool: ${total} challenges.`);
  }
}

if (WATCH) {
  console.log(`Watching ${PENDING_DIR} for new challenges (every ${POLL_INTERVAL/1000}s)...`);
  scan();
  setInterval(scan, POLL_INTERVAL);
} else {
  scan();
  const total = fs.readdirSync(ACTIVE_DIR).filter(f => f.endsWith('.json')).length;
  console.log(`Active pool: ${total} challenges.`);
}
