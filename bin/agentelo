#!/usr/bin/env node
'use strict';

const fs = require('fs');
const path = require('path');
const os = require('os');
const crypto = require('crypto');
const { execSync, execFileSync } = require('child_process');

const { score } = require('../core/scorer');
const { computeAgentHash } = require('../core/agentHash');
const {
  loadResults,
  sortResultsByDate,
  formatResultsTable,
  aggregateLeaderboard,
  formatLeaderboardTable,
} = require('../core/results');

// ---------------------------------------------------------------------------
// Paths
// ---------------------------------------------------------------------------
const PROJECT_ROOT = path.resolve(__dirname, '..');
const CHALLENGES_DIR = path.join(PROJECT_ROOT, 'challenges');
const RESULTS_DIR = path.join(PROJECT_ROOT, 'results');
const CACHE_DIR = path.join(PROJECT_ROOT, '.cache', 'repos');

// ---------------------------------------------------------------------------
// Arg parsing helpers
// ---------------------------------------------------------------------------
function parseArgs(argv) {
  const flags = {};
  for (let i = 0; i < argv.length; i++) {
    if (argv[i].startsWith('--')) {
      const key = argv[i].slice(2);
      const val = argv[i + 1] && !argv[i + 1].startsWith('--') ? argv[i + 1] : true;
      flags[key] = val;
      if (val !== true) i++;
    }
  }
  return flags;
}

// ---------------------------------------------------------------------------
// File-walk checksum helper
// ---------------------------------------------------------------------------
function checksumDir(dir) {
  const result = {};
  function walk(current, base) {
    let entries;
    try {
      entries = fs.readdirSync(current, { withFileTypes: true });
    } catch (_) {
      return;
    }
    for (const entry of entries) {
      const full = path.join(current, entry.name);
      // BUG 3 fix: normalize path separator to '/' for cross-platform consistency
      const rel = path.relative(base, full).split(path.sep).join('/');
      if (entry.isDirectory()) {
        // skip .git directory
        if (entry.name === '.git') continue;
        walk(full, base);
      } else if (entry.isFile()) {
        try {
          const content = fs.readFileSync(full);
          result[rel] = crypto.createHash('sha256').update(content).digest('hex');
        } catch (_) {
          // skip unreadable files
        }
      }
    }
  }
  walk(dir, dir);
  return result;
}

// ---------------------------------------------------------------------------
// tmux availability check
// ---------------------------------------------------------------------------
function hasTmux() {
  try {
    execFileSync('which', ['tmux'], { stdio: 'pipe' });
    return true;
  } catch (_) {
    return false;
  }
}

// ---------------------------------------------------------------------------
// Ensure results dir exists
// ---------------------------------------------------------------------------
function ensureResultsDir() {
  if (!fs.existsSync(RESULTS_DIR)) {
    fs.mkdirSync(RESULTS_DIR, { recursive: true });
  }
}

// ---------------------------------------------------------------------------
// Install dependencies — handles npm, pnpm, pip (with venv), cargo
// ---------------------------------------------------------------------------
function installDeps(dir) {
  try {
    if (fs.existsSync(path.join(dir, 'pnpm-lock.yaml'))) {
      execFileSync('pnpm', ['install', '--frozen-lockfile'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
    } else if (fs.existsSync(path.join(dir, 'package.json'))) {
      execFileSync('npm', ['install'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
    } else if (fs.existsSync(path.join(dir, 'pyproject.toml')) || fs.existsSync(path.join(dir, 'requirements.txt'))) {
      // Use venv to isolate Python deps — never install globally
      const venvDir = path.join(dir, '.venv');
      execFileSync('python3', ['-m', 'venv', venvDir], { cwd: dir, stdio: 'pipe', timeout: 60000 });
      const pip = path.join(venvDir, 'bin', 'pip');
      if (fs.existsSync(path.join(dir, 'pyproject.toml'))) {
        execFileSync(pip, ['install', '-e', '.'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
      } else {
        execFileSync(pip, ['install', '-r', 'requirements.txt'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
      }
    } else if (fs.existsSync(path.join(dir, 'Cargo.toml'))) {
      execFileSync('cargo', ['build'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
    }
  } catch (e) {
    console.warn('[agentelo] Dep install warning:', e.message?.slice(0, 200));
  }
}

// ---------------------------------------------------------------------------
// Normalize challenge JSON (miner uses nested structure, runner expects flat)
// ---------------------------------------------------------------------------
function normalizeChallenge(raw) {
  return {
    id:           raw.id,
    repo:         raw.repoUrl || raw.repo,
    commit:       raw.buggyCommit || raw.commit,
    fixCommit:    raw.fixCommit,
    fixDiff:      raw.fixDiff,
    title:        raw.issue?.title || raw.title || raw.id,
    body:         raw.issue?.body  || raw.body  || '',
    test_command: raw.testCommand  || raw.test_command || 'npm test',
    difficulty:   raw.difficulty,
  };
}

// ---------------------------------------------------------------------------
// POST result to API (non-blocking, non-fatal)
// ---------------------------------------------------------------------------
async function postToApi(result) {
  return new Promise((resolve) => {
    const body = JSON.stringify(result);
    const options = {
      hostname: 'localhost',
      port: 4000,
      path: '/api/submissions',
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(body),
      },
    };
    const req = require('http').request(options, (res) => {
      res.resume();
      res.on('end', () => resolve());
    });
    req.on('error', () => resolve());
    req.setTimeout(5000, () => { req.destroy(); resolve(); });
    req.write(body);
    req.end();
  });
}

// ---------------------------------------------------------------------------
// Fetch recommended challenges from API (sorted by attempt count)
// ---------------------------------------------------------------------------
async function fetchRecommendedChallenges() {
  return new Promise((resolve) => {
    const req = require('http').request({
      hostname: 'localhost',
      port: 4000,
      path: '/api/challenges/recommended',
      method: 'GET',
    }, (res) => {
      let data = '';
      res.on('data', chunk => { data += chunk; });
      res.on('end', () => {
        try { resolve(JSON.parse(data)); }
        catch (_) { resolve(null); }
      });
    });
    req.on('error', () => resolve(null));
    req.setTimeout(3000, () => { req.destroy(); resolve(null); });
    req.end();
  });
}

// ---------------------------------------------------------------------------
// Shared play/seed logic
// ---------------------------------------------------------------------------
async function runAgentPlay(flags, { isBaseline = false } = {}) {
  const harness = flags.harness;
  const model = flags.model;
  const challengeId = flags.challenge;

  if (!harness || !model) {
    const cmd = isBaseline ? 'seed' : 'play';
    console.error(`[agentelo] Usage: agentelo ${cmd} --harness <name> --model <model> [--challenge <id>]`);
    process.exit(1);
  }

  // Load challenge
  let challenge;
  if (challengeId) {
    const challengeFile = path.join(CHALLENGES_DIR, `${challengeId}.json`);
    if (!fs.existsSync(challengeFile)) {
      console.error(`[agentelo] Challenge not found: ${challengeId}`);
      process.exit(1);
    }
    challenge = normalizeChallenge(JSON.parse(fs.readFileSync(challengeFile, 'utf8')));
  } else {
    // Prefer challenges with most existing attempts (better ELO signal)
    let selected = null;
    const recommended = await fetchRecommendedChallenges();
    if (recommended && recommended.length > 0) {
      const pool = recommended.slice(0, 10);
      const picked = pool[Math.floor(Math.random() * pool.length)];
      const challengeFile = path.join(CHALLENGES_DIR, `${picked.id}.json`);
      if (fs.existsSync(challengeFile)) {
        selected = normalizeChallenge(JSON.parse(fs.readFileSync(challengeFile, 'utf8')));
      }
    }
    if (!selected) {
      const challengeFiles = fs.existsSync(CHALLENGES_DIR)
        ? fs.readdirSync(CHALLENGES_DIR).filter(f => f.endsWith('.json'))
        : [];
      if (challengeFiles.length === 0) {
        console.log("[agentelo] No challenges found in challenges/. Run 'agentelo mine' to fetch some.");
        process.exit(1);
      }
      const idx = Math.floor(Math.random() * challengeFiles.length);
      selected = normalizeChallenge(JSON.parse(fs.readFileSync(path.join(CHALLENGES_DIR, challengeFiles[idx]), 'utf8')));
    }
    challenge = selected;
  }
  console.log(`[agentelo] Challenge: ${challenge.id} — ${challenge.title?.slice(0, 60)}`);

  ensureResultsDir();

  // Generate run_id
  const timestamp = Math.floor(Date.now() / 1000);
  const rawRunId = `${challenge.id}-${harness}-${timestamp}`;

  // BUG 1 fix: validate runId to prevent shell injection via path interpolation
  if (!/^[a-zA-Z0-9._-]+$/.test(rawRunId)) {
    console.error('[agentelo] Invalid run ID contains unsafe characters.');
    process.exit(1);
  }
  const runId = rawRunId;

  // Create log file
  const logFile = path.join(RESULTS_DIR, `${runId}.log`);

  // BUG 1 fix: verify logFile path contains no single quotes before using in shell strings
  if (logFile.includes("'")) throw new Error('logFile path contains single quotes');

  fs.writeFileSync(logFile, '', 'utf8');

  // BUG 2 fix: wrap everything after temp dir creation in try/finally for cleanup
  const tmpdir = fs.mkdtempSync(path.join(os.tmpdir(), 'agentelo-'));
  let cleanDir = null;
  let fakeHome = null;

  try {
    // Use persistent repo cache — survives reboots, race-safe with lockfile
    const repoSlug = challenge.repo.replace('https://github.com/', '').replace(/\//g, '-');
    const cacheDir = path.join(CACHE_DIR, repoSlug);
    const lockFile = cacheDir + '.lock';
    fs.mkdirSync(CACHE_DIR, { recursive: true });

    // Race-safe clone: use lockfile to prevent concurrent clones
    if (!fs.existsSync(path.join(cacheDir, '.git', 'HEAD'))) {
      let lockFd;
      try {
        lockFd = fs.openSync(lockFile, 'wx'); // exclusive create — fails if exists
      } catch (_) {
        // Another process is cloning — wait for it (up to 5 min)
        console.log(`[agentelo] Waiting for another process to finish cloning ${repoSlug}...`);
        const deadline = Date.now() + 300000;
        while (!fs.existsSync(path.join(cacheDir, '.git', 'HEAD')) && Date.now() < deadline) {
          execFileSync('sleep', ['2']);
        }
        if (!fs.existsSync(path.join(cacheDir, '.git', 'HEAD'))) {
          throw new Error(`Timed out waiting for cache clone of ${repoSlug}`);
        }
        lockFd = null;
      }
      if (lockFd !== null && lockFd !== undefined) {
        try {
          console.log(`[agentelo] Caching repo ${challenge.repo}...`);
          // Clone to a temp name, then rename atomically
          const cloneTmp = cacheDir + '-cloning-' + process.pid;
          execFileSync('git', ['clone', '--filter=blob:none', challenge.repo, cloneTmp], { stdio: 'inherit', timeout: 600000 });
          fs.renameSync(cloneTmp, cacheDir);
          console.log('[agentelo] Cache ready.');
        } finally {
          fs.closeSync(lockFd);
          try { fs.unlinkSync(lockFile); } catch (_) {}
        }
      }
    } else {
      console.log(`[agentelo] Using cached repo for ${repoSlug}`);
    }

    // Copy cache to temp dir and checkout the buggy commit
    execFileSync('cp', ['-r', cacheDir + '/', tmpdir + '/'], { stdio: 'pipe' });
    execFileSync('git', ['checkout', '-f', challenge.commit], { cwd: tmpdir, stdio: 'pipe' });
    execFileSync('git', ['clean', '-fd'], { cwd: tmpdir, stdio: 'pipe' });
    // Install deps for the specific commit
    installDeps(tmpdir);
    console.log('[agentelo] Repo ready.');

    // Anti-cheat: checksum BEFORE (after deps install so node_modules isn't flagged)
    const beforeChecksums = checksumDir(tmpdir);

    // Build prompt
    const prompt =
      `You are being evaluated by AgentElo. This is an autonomous challenge — no human will respond. ` +
      `Do not ask questions. Fix the following issue using only the codebase and issue description provided. ` +
      `Work until you have a complete solution, then stop.\n\n` +
      `Issue: ${challenge.title}\n${challenge.body}\n\n` +
      `The repo is in your current working directory. Run tests with: ${challenge.test_command}.`;

    const startedAt = new Date().toISOString();

    // Build harness command — direct subprocess, no OpenFleet
    let cmd, cmdArgs;
    switch (harness) {
      case 'claude-code':
        cmd = 'claude';
        // Don't use --bare for baselines — need keychain auth. Fake HOME hides user configs.
        cmdArgs = ['-p', prompt, '--dangerously-skip-permissions', '--model', model];
        break;
      case 'opencode':
        cmd = 'opencode';
        cmdArgs = ['run', '--dir', tmpdir, '--model', model, prompt];
        break;
      case 'codex':
        cmd = 'codex';
        cmdArgs = ['-m', model, '--full-auto', prompt];
        break;
      default:
        throw new Error(`Unsupported harness: ${harness}`);
    }

    // Set up environment
    const runEnv = { ...process.env };
    // NOTE: not overriding HOME — all harnesses need auth from user's home dir.
    // Baseline isolation comes from the clean workdir (no .claude/, .opencode/, etc)

    console.log(`[agentelo] Running: ${cmd} ${cmdArgs[0]}... (stdin closed, 30min timeout)`);
    console.log(`[agentelo] Log: ${logFile}`);

    // Run as subprocess — stdin closed, stdout/stderr captured to log
    const logStream = fs.createWriteStream(logFile);
    let timedOut = false;

    const startMs = Date.now();
    await new Promise((resolve) => {
      const child = require('child_process').spawn(cmd, cmdArgs, {
        cwd: tmpdir,
        env: runEnv,
        stdio: ['pipe', 'pipe', 'pipe'],  // stdin=pipe (we close it), stdout+stderr=pipe
        timeout: 30 * 60 * 1000,
      });
      // Close stdin immediately — no human input
      child.stdin.end();
      // Capture output
      child.stdout.pipe(logStream);
      child.stderr.pipe(logStream);
      child.stdout.pipe(process.stdout);
      child.stderr.pipe(process.stderr);
      // Timeout
      const timer = setTimeout(() => {
        timedOut = true;
        console.log('\n[agentelo] Timeout (30 min). Killing agent.');
        child.kill('SIGTERM');
        setTimeout(() => child.kill('SIGKILL'), 5000);
      }, 30 * 60 * 1000);
      child.on('close', (code) => {
        clearTimeout(timer);
        logStream.end();
        const elapsed = Math.round((Date.now() - startMs) / 1000);
        console.log(`\n[agentelo] Agent exited (code ${code}) after ${elapsed}s`);
        resolve();
      });
    });

    const finishedAt = new Date().toISOString();

    // Clean up tmux viewer if any
    try {
      execFileSync('tmux', ['kill-window', '-t', `openfleet:${runId}-view`], { stdio: 'pipe' });
    } catch (_) {}

    // Anti-cheat: checksum AFTER
    const afterChecksums = checksumDir(tmpdir);

    // Get git diff names
    let gitDiffNames = [];
    try {
      const diffNameOut = execSync('git diff --name-only', { cwd: tmpdir, stdio: 'pipe' }).toString().trim();
      gitDiffNames = diffNameOut.split('\n').filter(Boolean);
    } catch (_) {}

    // Detect tampered files
    const tamperedFiles = [];
    for (const [relpath, beforeHash] of Object.entries(beforeChecksums)) {
      if (afterChecksums[relpath] !== beforeHash && !gitDiffNames.includes(relpath)) {
        tamperedFiles.push(relpath);
      }
    }
    // Also flag new files not in git diff
    for (const relpath of Object.keys(afterChecksums)) {
      if (!beforeChecksums[relpath] && !gitDiffNames.includes(relpath)) {
        tamperedFiles.push(relpath);
      }
    }
    const tampered = tamperedFiles.length > 0;

    // Collect git diff
    let diff = '';
    try {
      diff = execSync('git diff', { cwd: tmpdir, stdio: 'pipe' }).toString();
    } catch (_) {}

    // Create clean copy for scoring — use cache instead of re-cloning
    cleanDir = fs.mkdtempSync(path.join(os.tmpdir(), 'agentelo-clean-'));
    try {
      execFileSync('cp', ['-r', cacheDir + '/', cleanDir + '/'], { stdio: 'pipe' });
      execFileSync('git', ['checkout', '-f', challenge.commit], { cwd: cleanDir, stdio: 'pipe' });
      execFileSync('git', ['clean', '-fd'], { cwd: cleanDir, stdio: 'pipe' });
      installDeps(cleanDir);
    } catch (err) {
      console.error('[agentelo] Failed to prepare clean repo for scoring:', err.message?.slice(0, 200));
    }

    // Score
    let scoreResult = { tests_passed: false, time_seconds: 0, exit_code: 1, diff_lines: 0 };
    try {
      scoreResult = await score(diff, cleanDir, challenge, logFile);
    } catch (err) {
      console.error('[agentelo] Scoring error:', err.message);
    }

    // Compute agent_hash
    let agentHash;
    let configFiles;
    if (isBaseline) {
      // For seed: hash is just harness + model since HOME is isolated
      agentHash = crypto
        .createHash('sha256')
        .update(`${harness}:${model}`)
        .digest('hex')
        .slice(0, 12);
      configFiles = [];
    } else {
      const hashResult = await computeAgentHash(harness, model, tmpdir);
      agentHash = hashResult.hash;
      configFiles = hashResult.configFiles;
    }

    // Build result object
    const result = {
      run_id: runId,
      challenge_id: challenge.id,
      harness,
      model,
      agent_hash: agentHash,
      started_at: startedAt,
      finished_at: finishedAt,
      tests_passed: scoreResult.tests_passed,
      time_seconds: scoreResult.time_seconds,
      exit_code: scoreResult.exit_code,
      diff_lines: scoreResult.diff_lines,
      diff,
      tampered,
      tampered_files: tamperedFiles,
      log_file: logFile,
      timed_out: timedOut,
      config_files: configFiles,
      ...(isBaseline ? { baseline: true, home_isolation: fakeHome } : {}),
      ...(isBaseline ? { config_files_hashed: [] } : {}),
    };

    // Save result
    const resultFile = path.join(RESULTS_DIR, `${runId}.json`);
    fs.writeFileSync(resultFile, JSON.stringify(result, null, 2), 'utf8');

    // Print summary
    console.log('\n[agentelo] Done!');
    console.log(`Challenge: ${challenge.id}`);
    console.log(`Tests passed: ${result.tests_passed ? 'YES' : 'NO'}`);
    console.log(`Time: ${Math.round(result.time_seconds)}s`);
    console.log(`Diff lines: ${result.diff_lines}`);
    console.log(`Tampered: ${tampered ? 'YES' : 'NO'}`);
    console.log(`Result saved: results/${runId}.json`);
    if (isBaseline) {
      console.log(`Baseline: true (HOME isolated to ${fakeHome})`);
    }

    // Post to API (non-blocking, best-effort — silently skip if API not running)
    await postToApi(result);

  } finally {
    // BUG 2 fix: always clean up temp dirs
    try { fs.rmSync(tmpdir, { recursive: true, force: true }); } catch (_) {}
    if (cleanDir) try { fs.rmSync(cleanDir, { recursive: true, force: true }); } catch (_) {}
    if (fakeHome) try { fs.rmSync(fakeHome, { recursive: true, force: true }); } catch (_) {}
  }
}

// ---------------------------------------------------------------------------
// subcommand: play
// ---------------------------------------------------------------------------
async function cmdPlay(flags) {
  return runAgentPlay(flags, { isBaseline: false });
}

// ---------------------------------------------------------------------------
// subcommand: seed
// ---------------------------------------------------------------------------
async function cmdSeed(flags) {
  return runAgentPlay(flags, { isBaseline: true });
}

// ---------------------------------------------------------------------------
// subcommand: results
// ---------------------------------------------------------------------------
function cmdResults() {
  ensureResultsDir();
  const results = loadResults(RESULTS_DIR);
  if (results.length === 0) {
    console.log('[agentelo] No results yet.');
    return;
  }
  const sorted = sortResultsByDate(results);
  console.log(formatResultsTable(sorted));
}

// ---------------------------------------------------------------------------
// subcommand: leaderboard
// ---------------------------------------------------------------------------
function cmdLeaderboard() {
  ensureResultsDir();
  const results = loadResults(RESULTS_DIR);
  if (results.length === 0) {
    console.log('[agentelo] No results yet.');
    return;
  }
  const leaderboard = aggregateLeaderboard(results);
  console.log(formatLeaderboardTable(leaderboard));
}

// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------
const subcommand = process.argv[2];
const flags = parseArgs(process.argv.slice(3));

switch (subcommand) {
  case 'play':
    cmdPlay(flags).catch(err => {
      console.error('[agentelo] Fatal error:', err.message);
      process.exit(1);
    });
    break;
  case 'seed':
    cmdSeed(flags).catch(err => {
      console.error('[agentelo] Fatal error:', err.message);
      process.exit(1);
    });
    break;
  case 'results':
    cmdResults();
    break;
  case 'leaderboard':
    cmdLeaderboard();
    break;
  default:
    console.log('Usage: agentelo <command> [options]');
    console.log('');
    console.log('Commands:');
    console.log('  play         Run an agent against a challenge');
    console.log('  seed         Run agent with isolated HOME (baseline seeding only)');
    console.log('  results      Show all past run results');
    console.log('  leaderboard  Show ELO-style leaderboard');
    console.log('');
    console.log('Options for play/seed:');
    console.log('  --harness <name>    Agent harness (e.g. claude-code)');
    console.log('  --model <model>     Model name (e.g. claude-sonnet-4-6)');
    console.log('  --challenge <id>    Challenge ID (random if omitted)');
    process.exit(subcommand ? 1 : 0);
}
