const VERTEX_PROJECT = process.env.AGENTELO_GCP_PROJECT || '';

function getVertexInfo(model) {
  return VERTEX_MODELS[model] || null;
}

function getVertexOpenAIBaseUrl(location) {
  if (location === 'global') {
    return `https://aiplatform.googleapis.com/v1beta1/projects/${VERTEX_PROJECT}/locations/global/endpoints/openapi`;
  }
  return `https://${location}-aiplatform.googleapis.com/v1beta1/projects/${VERTEX_PROJECT}/locations/${location}/endpoints/openapi`;
}

function getGcloudToken() {
  try {
    return execSync('gcloud auth application-default print-access-token 2>/dev/null', { encoding: 'utf8' }).trim();
  } catch {
    return null;
  }
}

function getOpenCodeSessionStatus(tmpdir) {
  try {
    const ocDb = path.join(os.homedir(), '.local', 'share', 'opencode', 'opencode.db');
    if (!fs.existsSync(ocDb)) return null;
    const { execSync: ex } = require('child_process');
    const base = path.basename(tmpdir).replace(/'/g, "''");
    const row = ex(
      `sqlite3 "${ocDb}" "SELECT id, time_created, time_updated, (SELECT COUNT(*) FROM message WHERE session_id = session.id), (SELECT data FROM message WHERE session_id = session.id ORDER BY time_created DESC LIMIT 1) FROM session WHERE directory LIKE '%${base}%' ORDER BY time_updated DESC LIMIT 1"`,
      { encoding: 'utf8', timeout: 5000 }
    ).trim();
    if (!row) return null;
    const [id, created, updated, messageCount, lastMessageJson] = row.split('|');
    let lastMode = null;
    let lastRole = null;
    let lastTokensIn = 0;
    let lastTokensOut = 0;
    if (lastMessageJson) {
      try {
        const parsed = JSON.parse(lastMessageJson);
        lastMode = parsed.mode || null;
        lastRole = parsed.role || null;
        lastTokensIn = Number(parsed.tokens?.input || 0);
        lastTokensOut = Number(parsed.tokens?.output || 0);
      } catch {}
    }
    return {
      id,
      timeCreated: Number(created) || 0,
      timeUpdated: Number(updated) || 0,
      messageCount: Number(messageCount) || 0,
      lastMode,
      lastRole,
      lastTokensIn,
      lastTokensOut,
    };
  } catch {
    return null;
  }
}

// ---------------------------------------------------------------------------
// Arg parsing helpers
// ---------------------------------------------------------------------------
function parseArgs(argv) {
  const flags = {};
  for (let i = 0; i < argv.length; i++) {
    if (argv[i].startsWith('--')) {
      const key = argv[i].slice(2);
      const val = argv[i + 1] && !argv[i + 1].startsWith('--') ? argv[i + 1] : true;
      flags[key] = val;
      if (val !== true) i++;
    }
  }
  return flags;
}

// ---------------------------------------------------------------------------
// Server URL resolution
// ---------------------------------------------------------------------------
function getBaseUrl(flags) {
  const baseUrl = (flags && flags.server)
    ? flags.server.replace(/\/+$/, '')
    : (process.env.AGENTELO_URL || 'https://api.agentelo.io').replace(/\/+$/, '');
  if (!baseUrl.startsWith('https://') && !baseUrl.includes('localhost')) {
    console.error('[agentelo] WARNING: Using non-HTTPS connection. API key transmitted in plaintext.');
  }
  return baseUrl;
}

// ---------------------------------------------------------------------------
// File-walk checksum helper
// ---------------------------------------------------------------------------
function checksumDir(dir) {
  const result = {};
  function walk(current, base) {
    let entries;
    try {
      entries = fs.readdirSync(current, { withFileTypes: true });
    } catch (_) {
      return;
    }
    for (const entry of entries) {
      const full = path.join(current, entry.name);
      // BUG 3 fix: normalize path separator to '/' for cross-platform consistency
      const rel = path.relative(base, full).split(path.sep).join('/');
      if (entry.isDirectory()) {
        // skip .git directory
        if (entry.name === '.git') continue;
        walk(full, base);
      } else if (entry.isFile()) {
        try {
          const content = fs.readFileSync(full);
          result[rel] = crypto.createHash('sha256').update(content).digest('hex');
        } catch (_) {
          // skip unreadable files
        }
      }
    }
  }
  walk(dir, dir);
  return result;
}

// ---------------------------------------------------------------------------
// tmux availability check
// ---------------------------------------------------------------------------
function hasTmux() {
  try {
    execFileSync('which', ['tmux'], { stdio: 'pipe' });
    return true;
  } catch (_) {
    return false;
  }
}

// ---------------------------------------------------------------------------
// Ensure results dir exists
// ---------------------------------------------------------------------------
function ensureResultsDir() {
  if (!fs.existsSync(RESULTS_DIR)) {
    fs.mkdirSync(RESULTS_DIR, { recursive: true });
  }
}

// ---------------------------------------------------------------------------
// Install dependencies — handles npm, pnpm, pip (with venv), cargo
// ---------------------------------------------------------------------------
function installDeps(dir) {
  try {
    if (fs.existsSync(path.join(dir, 'pnpm-lock.yaml'))) {
      // pnpm monorepos — install without frozen lockfile (commit may predate lockfile)
      execFileSync('pnpm', ['install', '--no-frozen-lockfile'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
    } else if (fs.existsSync(path.join(dir, 'package.json'))) {
      execFileSync('npm', ['install'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
    } else if (fs.existsSync(path.join(dir, 'pyproject.toml')) || fs.existsSync(path.join(dir, 'setup.py')) || fs.existsSync(path.join(dir, 'requirements.txt'))) {
      // Use uv + venv to isolate Python deps — never install globally
      const venvDir = path.join(dir, '.venv');
      const venvPython = path.join(venvDir, 'bin', 'python');
      execFileSync('uv', ['venv', '-p', '3.12', venvDir], { cwd: dir, stdio: 'pipe', timeout: 60000 });
      if (fs.existsSync(path.join(dir, 'pyproject.toml')) || fs.existsSync(path.join(dir, 'setup.py'))) {
        // Install package + test deps — use non-editable (editable breaks with flit/hatch)
        const extraCombos = ['.[dev,tests]', '.[dev,test]', '.[all]', '.[tests]', '.'];
        let installed = false;
        for (const extras of extraCombos) {
          try {
            execFileSync('uv', ['pip', 'install', extras, '--python', venvPython], { cwd: dir, stdio: 'pipe', timeout: 300000 });
            try {
              execFileSync(path.join(venvDir, 'bin', 'python3'), ['-c', 'import pytest'], { cwd: dir, stdio: 'pipe', timeout: 10000 });
              installed = true;
              console.log(`[installDeps] Python: uv pip install ${extras} succeeded (pytest verified)`);
              break;
            } catch (_) {
              console.log(`[installDeps] Python: ${extras} installed but pytest missing, trying next...`);
            }
          } catch (_) {}
        }
        if (!installed) console.warn('[installDeps] Python: all install combos failed');
        // ALWAYS ensure pytest is installed
        try { execFileSync('uv', ['pip', 'install', 'pytest', '--python', venvPython], { cwd: dir, stdio: 'pipe', timeout: 60000 }); } catch (_) {}
      } else if (fs.existsSync(path.join(dir, 'requirements.txt'))) {
        execFileSync('uv', ['pip', 'install', '-r', 'requirements.txt', '--python', venvPython], { cwd: dir, stdio: 'pipe', timeout: 300000 });
        try { execFileSync('uv', ['pip', 'install', 'pytest', '--python', venvPython], { cwd: dir, stdio: 'pipe', timeout: 60000 }); } catch (_) {}
      }
    } else if (fs.existsSync(path.join(dir, 'Cargo.toml'))) {
      execFileSync('cargo', ['build'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
    }
  } catch (e) {
    console.warn('[agentelo] Dep install warning:', e.message?.slice(0, 200));
  }
}

// ---------------------------------------------------------------------------
// Normalize challenge JSON (miner uses nested structure, runner expects flat)
// ---------------------------------------------------------------------------
function normalizeChallenge(raw) {
  return {
    id:               raw.id,
    repo:             raw.repoUrl || raw.repo,
    commit:           raw.buggyCommit || raw.commit,
    fixCommit:        raw.fixCommit,
    fixDiff:          raw.fixDiff,
    title:            raw.issue?.title || raw.title || raw.id,
    body:             raw.issue?.body  || raw.body  || '',
    test_command:     raw.testCommand  || raw.test_command || 'npm test',
    difficulty:       raw.difficulty,
    baseline_passing: raw.baseline_passing || 0,
    broken_by_bug:    raw.broken_by_bug || 0,
  };
}

// ---------------------------------------------------------------------------
// Slugify helper
// ---------------------------------------------------------------------------
function slugify(str) {
  return str.replace(/[\/\\.:\s]+/g, '-').replace(/[^a-zA-Z0-9-]/g, '').toLowerCase();
}

// ---------------------------------------------------------------------------
// POST to /api/register
// ---------------------------------------------------------------------------
async function postRegister(body, baseUrl) {
  return new Promise((resolve, reject) => {
    const data = JSON.stringify(body);
    const url = new URL('/api/register', baseUrl);
    const mod = url.protocol === 'https:' ? require('https') : require('http');
    const req = mod.request(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(data) }
    }, (res) => {
      let out = '';
      res.on('data', c => out += c);
      res.on('end', () => resolve({ status: res.statusCode, body: JSON.parse(out) }));
    });
    req.on('error', reject);
    req.setTimeout(5000, () => { req.destroy(); reject(new Error('timeout')); });
    req.write(data);
    req.end();
  });
}

// ---------------------------------------------------------------------------
// PATCH /api/agents/:id (display name update)
// ---------------------------------------------------------------------------
async function patchAgent(agentId, body, baseUrl) {
  return new Promise((resolve, reject) => {
    const data = JSON.stringify(body);
    const url = new URL(`/api/agents/${encodeURIComponent(agentId)}`, baseUrl);
    const mod = url.protocol === 'https:' ? require('https') : require('http');
    const req = mod.request(url, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(data) }
    }, (res) => {
      let out = '';
      res.on('data', c => out += c);
      res.on('end', () => {
        let parsed = null;
        try { parsed = out ? JSON.parse(out) : null; } catch {}
        resolve({ status: res.statusCode, body: parsed });
      });
    });
    req.on('error', reject);
    req.setTimeout(5000, () => { req.destroy(); reject(new Error('timeout')); });
    req.write(data);
    req.end();
  });
}

// ---------------------------------------------------------------------------
// subcommand: register
// ---------------------------------------------------------------------------
async function cmdRegister(flags) {
  if (!flags.name) {
    console.error('[agentelo] Usage: agentelo register --name <username> --harness <harness> --model <model>');
    process.exit(1);
  }
  if (!flags.harness || !flags.model) {
    console.error('[agentelo] Usage: agentelo register --name <username> --harness <harness> --model <model>');
    process.exit(1);
  }

  try {
    const { profanity } = require('@2toad/profanity');
    if (profanity && typeof profanity.exists === 'function' && profanity.exists(flags.name)) {
      console.error('Agent name not allowed. Choose a different name.');
      process.exit(1);
    }
  } catch (_) {
    // Optional dependency for local CLI checks; skip if not installed.
  }

  const baseUrl = getBaseUrl(flags);
  let res;
  try {
    res = await postRegister({ name: flags.name, harness: flags.harness, model: flags.model }, baseUrl);
  } catch (err) {
    console.error('[agentelo] Registration failed:', err.message);
    process.exit(1);
  }

  if (res.status === 409) {
    console.error('[agentelo] Agent name already taken');
    process.exit(1);
  }

  if (res.status !== 200 && res.status !== 201) {
    console.error('[agentelo] Registration error:', JSON.stringify(res.body));
    process.exit(1);
  }

  const { agent_id, api_key } = res.body;
  fs.mkdirSync(AGENTELO_DIR, { recursive: true });

  // Multi-agent credentials: store all agents keyed by name
  let creds = {};
  try { creds = JSON.parse(fs.readFileSync(CREDS_FILE, 'utf8')); } catch {}
  // Migrate old single-agent format
  if (creds.agent_id && creds.api_key && !creds.agents) {
    creds = { agents: { [creds.agent_id]: { api_key: creds.api_key } }, default: creds.agent_id };
  }
  if (!creds.agents) creds.agents = {};
  creds.agents[agent_id] = { api_key, harness, model };
  // Set as default if it's the first or only agent
  if (!creds.default || Object.keys(creds.agents).length === 1) creds.default = agent_id;
  fs.writeFileSync(CREDS_FILE, JSON.stringify(creds, null, 2));

  console.log(`Agent registered: ${agent_id}`);
  console.log(`API key: ${api_key}`);
  console.log(`Saved to ~/.agentelo/credentials.json`);
  if (Object.keys(creds.agents).length > 1) {
    console.log(`You have ${Object.keys(creds.agents).length} agents. Use --agent ${agent_id} to play as this one.`);
    console.log(`Default agent: ${creds.default}`);
  }
}

// ---------------------------------------------------------------------------
// subcommand: rename
// ---------------------------------------------------------------------------
async function cmdRename(flags) {
  if (!flags.name) {
    console.error('[agentelo] Usage: agentelo rename --name <new-name> [--agent <name>]');
    process.exit(1);
  }

  let agentId = null;
  let apiKey = null;
  try {
    const creds = JSON.parse(fs.readFileSync(CREDS_FILE, 'utf8'));
    if (creds.agents) {
      const selectedAgent = flags.agent || creds.default;
      if (!selectedAgent || !creds.agents[selectedAgent]) {
        console.error(`Agent "${selectedAgent || '(none)'}" not found. Run: agentelo agents`);
        process.exit(1);
      }
      agentId = selectedAgent;
      apiKey = creds.agents[selectedAgent].api_key;
    } else if (creds.agent_id && creds.api_key) {
      // Old single-agent format
      agentId = creds.agent_id;
      apiKey = creds.api_key;
    }
  } catch {
    console.error('No credentials found. Run: agentelo register');
    process.exit(1);
  }

  if (!agentId || !apiKey) {
    console.error('No credentials found. Run: agentelo register');
    process.exit(1);
  }

  const baseUrl = getBaseUrl(flags);
  let res;
  try {
    res = await patchAgent(agentId, { api_key: apiKey, display_name: flags.name }, baseUrl);
  } catch (err) {
    console.error('[agentelo] Rename failed:', err.message);
    process.exit(1);
  }

  if (res.status !== 200) {
    console.error('[agentelo] Rename error:', JSON.stringify(res.body));
    process.exit(1);
  }

  console.log(`Agent renamed: ${agentId} -> ${flags.name}`);
}

// ---------------------------------------------------------------------------
// List registered agents
// ---------------------------------------------------------------------------
function cmdAgents() {
  let creds = {};
  try { creds = JSON.parse(fs.readFileSync(CREDS_FILE, 'utf8')); } catch {}
  if (creds.agent_id && !creds.agents) {
    creds = { agents: { [creds.agent_id]: { api_key: creds.api_key } }, default: creds.agent_id };
  }
  const agents = creds.agents || {};
  if (Object.keys(agents).length === 0) {
    console.log('No agents registered. Run: agentelo register --name <name> --harness <harness> --model <model>');
    return;
  }
  console.log('Registered agents:');
  for (const [name, info] of Object.entries(agents)) {
    const def = name === creds.default ? ' (default)' : '';
    const details = info.harness ? ` [${info.harness}/${info.model}]` : '';
    console.log(`  ${name}${details}${def}`);
  }
  console.log(`\nUse --agent <name> to play as a specific agent.`);
  console.log(`Use: agentelo default --agent <name> to change the default.`);
}

// ---------------------------------------------------------------------------
// POST result to API (non-blocking, non-fatal)
// ---------------------------------------------------------------------------
async function postToApi(result, baseUrl) {
  return new Promise((resolve) => {
    const body = JSON.stringify(result);
    const url = new URL('/api/submissions', baseUrl);
    const mod = url.protocol === 'https:' ? require('https') : require('http');
    const req = mod.request(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(body),
      },
    }, (res) => {
      res.resume();
      res.on('end', () => resolve());
    });
    req.on('error', () => resolve());
    req.setTimeout(5000, () => { req.destroy(); resolve(); });
    req.write(body);
    req.end();
  });
}

// ---------------------------------------------------------------------------
// Fetch recommended challenges from API (sorted by attempt count)
// ---------------------------------------------------------------------------
async function fetchRecommendedChallenges(baseUrl) {
  return new Promise((resolve) => {
    const url = new URL('/api/challenges/recommended', baseUrl);
    const mod = url.protocol === 'https:' ? require('https') : require('http');
    const req = mod.request(url, { method: 'GET' }, (res) => {
      let data = '';
      res.on('data', chunk => { data += chunk; });
      res.on('end', () => {
        try { resolve(JSON.parse(data)); }
        catch (_) { resolve(null); }
      });
    });
    req.on('error', () => resolve(null));
    req.setTimeout(3000, () => { req.destroy(); resolve(null); });
    req.end();
  });
}

