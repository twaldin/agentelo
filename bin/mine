#!/usr/bin/env node
'use strict';

const { spawnSync } = require('child_process');
const fs = require('fs');
const path = require('path');

// --- Config ---

const REPOS = [
  // Node.js / JS
  'expressjs/express',
  'fastify/fastify',
  'vercel/next.js',
  'remix-run/remix',
  'koajs/koa',
  'nestjs/nest',
  'prisma/prisma',
  'trpc/trpc',
  'drizzle-team/drizzle-orm',
  'vitejs/vite',
  'esbuild/esbuild',
  // Frontend
  'facebook/react',
  'vuejs/core',
  'sveltejs/svelte',
  'angular/angular',
  'shadcn-ui/ui',
  // Python
  'pallets/flask',
  'tiangolo/fastapi',
  'django/django',
  'pydantic/pydantic',
  'psf/requests',
  // Go
  'golang/go',
  'gin-gonic/gin',
  'gofiber/fiber',
  // Rust
  'tokio-rs/tokio',
  'serde-rs/serde',
  // Tools
  'jqlang/jq',
  'BurntSushi/ripgrep',
  'denoland/deno',
];

const CHALLENGES_DIR = path.resolve(__dirname, '..', 'challenges');
const NINETY_DAYS_AGO = new Date(Date.now() - 365 * 24 * 60 * 60 * 1000);
const MAX_FILES = 30;
const MAX_LINES = 2000;

fs.mkdirSync(CHALLENGES_DIR, { recursive: true });

// --- Shell helpers ---

function run(cmd, args, { input, allowFail } = {}) {
  const res = spawnSync(cmd, args, {
    encoding: 'utf8',
    maxBuffer: 20 * 1024 * 1024,
    ...(input != null ? { input } : {}),
  });
  if (res.status !== 0 && !allowFail) {
    const msg = (res.stderr || '').trim() || res.error?.message || 'failed';
    throw new Error(`${cmd} ${args.slice(0, 2).join(' ')}: ${msg}`);
  }
  return res;
}

function graphql(query, variables = {}) {
  const res = run('gh', ['api', 'graphql', '--input', '-'], {
    input: JSON.stringify({ query, variables }),
  });
  const parsed = JSON.parse(res.stdout);
  if (parsed.errors?.length) {
    throw new Error(parsed.errors.map(e => e.message).join('; '));
  }
  return parsed.data;
}

// --- Test command detection (cached per repo) ---

const testCmdCache = new Map();

function fetchFileContent(owner, name, filepath) {
  const res = run('gh', ['api', `repos/${owner}/${name}/contents/${filepath}`], { allowFail: true });
  if (res.status !== 0 || !res.stdout.trim()) return null;
  try {
    const obj = JSON.parse(res.stdout);
    if (obj.content && obj.encoding === 'base64') {
      return Buffer.from(obj.content.replace(/\s/g, ''), 'base64').toString('utf8');
    }
  } catch {}
  return null;
}

function detectTestCommand(repo) {
  if (testCmdCache.has(repo)) return testCmdCache.get(repo);
  const [owner, name] = repo.split('/');
  let cmd = null;

  // package.json → Node
  if (!cmd) {
    const content = fetchFileContent(owner, name, 'package.json');
    if (content) {
      try {
        const pkg = JSON.parse(content);
        const test = pkg.scripts?.test;
        if (test && !test.includes('no test') && !test.includes('echo')) cmd = 'npm test';
      } catch {}
    }
  }

  // Cargo.toml → Rust
  if (!cmd && fetchFileContent(owner, name, 'Cargo.toml')) cmd = 'cargo test';

  // go.mod → Go
  if (!cmd && fetchFileContent(owner, name, 'go.mod')) cmd = 'go test ./...';

  // pyproject.toml → Python
  if (!cmd && fetchFileContent(owner, name, 'pyproject.toml')) cmd = 'pytest';

  // setup.py → Python
  if (!cmd && fetchFileContent(owner, name, 'setup.py')) cmd = 'pytest';

  // Makefile test target
  if (!cmd) {
    const content = fetchFileContent(owner, name, 'Makefile');
    if (content && /^test\s*:/m.test(content)) cmd = 'make test';
  }

  testCmdCache.set(repo, cmd);
  return cmd;
}

// --- GitHub GraphQL query for bug issues with linked PRs ---

const ISSUES_QUERY = `
query GetBugIssues($owner: String!, $name: String!, $cursor: String) {
  repository(owner: $owner, name: $name) {
    issues(
      labels: ["bug"]
      states: [CLOSED]
      first: 50
      after: $cursor
      orderBy: { field: UPDATED_AT, direction: DESC }
    ) {
      pageInfo { hasNextPage endCursor }
      nodes {
        number
        title
        body
        closedAt
        timelineItems(first: 10, itemTypes: [CLOSED_EVENT]) {
          nodes {
            ... on ClosedEvent {
              closer {
                ... on PullRequest {
                  number
                  merged
                  mergeCommit {
                    oid
                    parents(first: 2) {
                      nodes { oid }
                    }
                  }
                  additions
                  deletions
                  changedFiles
                }
              }
            }
          }
        }
      }
    }
  }
}
`;

function fetchIssues(owner, name) {
  const all = [];
  let cursor = null;
  let pages = 0;

  while (pages < 3) {
    const data = graphql(ISSUES_QUERY, { owner, name, cursor });
    const page = data.repository.issues;

    for (const issue of page.nodes) {
      if (!issue.closedAt) continue;
      if (new Date(issue.closedAt) >= NINETY_DAYS_AGO) {
        all.push(issue);
      }
    }

    if (!page.pageInfo.hasNextPage) break;

    // Stop paginating if the oldest on this page is outside the window
    const oldest = page.nodes[page.nodes.length - 1];
    if (oldest && new Date(oldest.closedAt) < NINETY_DAYS_AGO) break;

    cursor = page.pageInfo.endCursor;
    pages++;
  }

  return all;
}

// --- PR diff fetching ---

function fetchPRDiff(repo, prNumber) {
  const res = run('gh', ['pr', 'diff', String(prNumber), '--repo', repo], { allowFail: true });
  if (res.status === 0 && res.stdout) return res.stdout;

  // Fallback: reconstruct from files API (patch may be truncated for large files)
  const [owner, name] = repo.split('/');
  const filesRes = run('gh', ['api', `repos/${owner}/${name}/pulls/${prNumber}/files`], { allowFail: true });
  if (filesRes.status !== 0) return null;
  try {
    const files = JSON.parse(filesRes.stdout);
    const parts = files
      .filter(f => f.patch)
      .map(f => `diff --git a/${f.filename} b/${f.filename}\n--- a/${f.filename}\n+++ b/${f.filename}\n${f.patch}`);
    return parts.join('\n') || null;
  } catch {}
  return null;
}

// --- Build challenge object ---

function buildChallenge(repo, issue) {
  const [, name] = repo.split('/');

  // Find first merged PR closer
  let pr = null;
  for (const event of (issue.timelineItems?.nodes || [])) {
    if (event.closer?.merged && event.closer.mergeCommit) {
      pr = event.closer;
      break;
    }
  }
  if (!pr) return null;

  // Filter: skip very large PRs
  const totalLines = pr.additions + pr.deletions;
  if (pr.changedFiles > MAX_FILES) return null;
  if (totalLines > MAX_LINES) return null;

  const fixCommit = pr.mergeCommit.oid;
  const parents = pr.mergeCommit.parents.nodes;
  if (!parents.length) return null;
  const buggyCommit = parents[0].oid; // state of repo before the fix was applied

  const fixDiff = fetchPRDiff(repo, pr.number);
  const testCommand = detectTestCommand(repo);

  return {
    id: `${name}-${issue.number}`,
    repo,
    repoUrl: `https://github.com/${repo}`,
    issue: {
      number: issue.number,
      title: issue.title,
      body: issue.body || '',
    },
    pr: {
      number: pr.number,
      url: `https://github.com/${repo}/pull/${pr.number}`,
    },
    buggyCommit,
    fixCommit,
    fixDiff,
    testCommand,
    difficulty: {
      filesChanged: pr.changedFiles,
      linesAdded: pr.additions,
      linesRemoved: pr.deletions,
    },
    minedAt: new Date().toISOString(),
  };
}

// --- Per-repo mining ---

function mineRepo(repo) {
  const [owner, name] = repo.split('/');
  process.stdout.write(`\n[${repo}] fetching issues... `);

  let issues;
  try {
    issues = fetchIssues(owner, name);
  } catch (e) {
    console.error(`FAILED: ${e.message}`);
    return 0;
  }
  console.log(`${issues.length} in 90-day window`);

  let saved = 0;
  for (const issue of issues) {
    const id = `${name}-${issue.number}`;
    const outPath = path.join(CHALLENGES_DIR, `${id}.json`);

    if (fs.existsSync(outPath)) {
      console.log(`  skip ${id} (exists)`);
      continue;
    }

    let challenge;
    try {
      challenge = buildChallenge(repo, issue);
    } catch (e) {
      console.warn(`  error #${issue.number}: ${e.message}`);
      continue;
    }

    if (!challenge) {
      const title = (issue.title || '').slice(0, 60);
      console.log(`  skip #${issue.number} "${title}" — no qualifying PR`);
      continue;
    }

    fs.writeFileSync(outPath, JSON.stringify(challenge, null, 2));
    saved++;
    const { filesChanged, linesAdded, linesRemoved } = challenge.difficulty;
    console.log(`  saved ${id} (+${linesAdded}/-${linesRemoved} in ${filesChanged} files)`);
  }

  return saved;
}

// --- Entry point ---

console.log('AgentElo Challenge Miner');
console.log(`Window: ${NINETY_DAYS_AGO.toISOString().split('T')[0]} → today`);
console.log(`Output: ${CHALLENGES_DIR}`);

let total = 0;
for (const repo of REPOS) {
  total += mineRepo(repo);
}

console.log(`\nDone. ${total} challenges saved to ${CHALLENGES_DIR}`);
