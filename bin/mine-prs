#!/usr/bin/env node
'use strict';

// Mine challenges from merged fix PRs directly (no issue linking required).
// Searches for PRs with "fix" in title that add test files,
// then validates they produce broken_by_bug >= MIN_BROKEN.

const { spawnSync, execSync } = require('child_process');
const fs = require('fs');
const path = require('path');
const os = require('os');

const DEFAULT_REPOS = [
  // JavaScript/TypeScript
  'fastify/fastify', 'koajs/koa', 'expressjs/express', 'honojs/hono',
  'sveltejs/svelte', 'mochajs/mocha', 'chalk/chalk', 'sindresorhus/execa',
  'yargs/yargs', 'hapijs/hapi', 'hapijs/joi', 'debug-js/debug',
  'ljharb/qs', 'tj/commander.js', 'expressjs/body-parser', 'socketio/socket.io',
  'typeorm/typeorm', 'sequelize/sequelize', 'jestjs/jest',
  'pnpm/pnpm', 'date-fns/date-fns', 'colinhacks/zod',
  // Python
  'psf/requests', 'pallets/flask', 'pallets/click', 'encode/httpx',
  'pydantic/pydantic', 'tiangolo/fastapi', 'marshmallow-code/marshmallow',
  'python-attrs/attrs', 'jazzband/pip-tools', 'tox-dev/tox',
  // Go
  'gin-gonic/gin', 'labstack/echo', 'go-chi/chi', 'gofiber/fiber',
  'stretchr/testify',
  // Rust
  'serde-rs/serde', 'tokio-rs/tokio', 'clap-rs/clap',
];

const cliArgs = process.argv.slice(2);
const cliRepos = [];
for (let i = 0; i < cliArgs.length; i++) {
  if (cliArgs[i] === '--repo' && cliArgs[i + 1]) cliRepos.push(cliArgs[++i]);
}
const ACTIVE_REPOS = cliRepos.length > 0 ? cliRepos : DEFAULT_REPOS;
const MIN_BROKEN = parseInt(process.env.MIN_BROKEN || '3', 10);

const CHALLENGES_DIR = path.resolve(__dirname, '..', process.env.MINE_OUTPUT || 'challenges-pending');
const CACHE_DIR = path.resolve(__dirname, '..', '.cache', 'repos');
fs.mkdirSync(CHALLENGES_DIR, { recursive: true });
fs.mkdirSync(CACHE_DIR, { recursive: true });

function run(cmd, args, opts = {}) {
  const res = spawnSync(cmd, args, { encoding: 'utf8', maxBuffer: 20 * 1024 * 1024, ...opts });
  if (res.status !== 0 && !opts.allowFail) {
    throw new Error(`${cmd} ${args.slice(0, 2).join(' ')}: ${(res.stderr || '').trim().slice(0, 200)}`);
  }
  return res;
}

// Search for merged fix PRs
function searchFixPRs(repo) {
  const queries = [
    'fix in:title',
    'bug in:title',
    'resolve in:title',
  ];
  const seen = new Set();
  const all = [];

  for (const q of queries) {
    const res = run('gh', [
      'pr', 'list', '--repo', repo,
      '--state', 'merged', '--search', q,
      '--limit', '50',
      '--json', 'number,title,mergeCommit,additions,deletions,changedFiles,mergedAt,files',
    ], { allowFail: true });
    if (res.status !== 0 || !res.stdout.trim()) continue;

    try {
      for (const pr of JSON.parse(res.stdout)) {
        if (seen.has(pr.number)) continue;
        seen.add(pr.number);
        if (!pr.mergedAt) continue;
        // Size filters
        if (pr.changedFiles > 30 || (pr.additions + pr.deletions) > 2000) continue;
        // Must have at least some additions (not just deletions)
        if (pr.additions < 3) continue;
        // Skip chore/docs/ci
        const t = (pr.title || '').toLowerCase();
        if (/^(chore|docs|ci|build|style|refactor|revert)\b/.test(t)) continue;
        all.push(pr);
      }
    } catch {}
  }
  return all;
}

function ensureRepoCache(repo) {
  const slug = repo.replace(/\//g, '-');
  const dir = path.join(CACHE_DIR, slug);
  if (fs.existsSync(path.join(dir, '.git'))) {
    try { spawnSync('git', ['fetch', '--all'], { cwd: dir, stdio: 'pipe', timeout: 120000 }); } catch {}
    return dir;
  }
  console.log(`  Cloning ${repo}...`);
  const res = spawnSync('git', ['clone', '--bare', `https://github.com/${repo}.git`, dir + '/.git'], {
    stdio: 'pipe', timeout: 300000,
  });
  if (res.status !== 0) return null;
  spawnSync('git', ['config', '--bool', 'core.bare', 'false'], { cwd: dir, stdio: 'pipe' });
  return dir;
}

function detectLanguage(repo) {
  const [owner, name] = repo.split('/');
  // Check for language-specific files
  const checks = [
    { file: 'package.json', lang: 'javascript' },
    { file: 'setup.py', lang: 'python' }, { file: 'pyproject.toml', lang: 'python' },
    { file: 'go.mod', lang: 'go' },
    { file: 'Cargo.toml', lang: 'rust' },
    { file: 'Gemfile', lang: 'ruby' },
  ];
  for (const c of checks) {
    const r = run('gh', ['api', `repos/${owner}/${name}/contents/${c.file}`, '--jq', '.name'], { allowFail: true });
    if (r.status === 0 && (r.stdout || '').trim()) return c.lang;
  }
  // Fallback: check GitHub language API
  const langRes = run('gh', ['api', `repos/${owner}/${name}`, '--jq', '.language'], { allowFail: true });
  const lang = (langRes.stdout || '').trim().toLowerCase();
  if (lang === 'python') return 'python';
  if (lang === 'go' || lang === 'golang') return 'go';
  if (lang === 'rust') return 'rust';
  if (lang === 'ruby') return 'ruby';
  return 'javascript';
}

function detectTestCommand(repo) {
  const lang = detectLanguage(repo);
  const [owner, name] = repo.split('/');

  if (lang === 'python') {
    // Check for pytest in pyproject.toml or setup.cfg
    return 'python -m pytest';
  }
  if (lang === 'go') return 'go test ./...';
  if (lang === 'rust') return 'cargo test';
  if (lang === 'ruby') return 'bundle exec rake test';

  // JavaScript/TypeScript
  const bunCheck = run('gh', ['api', `repos/${owner}/${name}/contents/bun.lock`, '--jq', '.name'], { allowFail: true });
  if (bunCheck.status === 0 && (bunCheck.stdout || '').trim()) return 'bun test';
  const pnpmCheck = run('gh', ['api', `repos/${owner}/${name}/contents/pnpm-lock.yaml`, '--jq', '.name'], { allowFail: true });
  const hasPnpm = pnpmCheck.status === 0 && (pnpmCheck.stdout || '').trim();
  const pkgRes = run('gh', ['api', `repos/${owner}/${name}/contents/package.json`], { allowFail: true });
  if (pkgRes.status === 0) {
    try {
      const obj = JSON.parse(pkgRes.stdout);
      if (obj.content) {
        const pkg = JSON.parse(Buffer.from(obj.content.replace(/\s/g, ''), 'base64').toString());
        if (pkg.scripts?.test && !pkg.scripts.test.includes('no test')) {
          return hasPnpm ? 'pnpm test' : 'npm test';
        }
      }
    } catch {}
  }
  return null;
}

function parseTestCounts(output) {
  // vitest
  const vt = output.match(/Tests\s+(\d+)\s+passed.*?\((\d+)\)/);
  if (vt) return { pass: parseInt(vt[1]), total: parseInt(vt[2]) };
  // jest
  const jp = output.match(/Tests:\s*(?:\d+\s+\w+,\s*)*?(\d+)\s+passed/);
  const jt = output.match(/Tests:\s*(?:\d+\s+\w+,\s*)*?(\d+)\s+total/);
  if (jp && jt) return { pass: parseInt(jp[1]), total: parseInt(jt[1]) };
  // node --test (ℹ or #)
  const np = output.match(/^[#ℹ]?\s*pass\s+(\d+)/m);
  const nt = output.match(/^[#ℹ]?\s*tests\s+(\d+)/m);
  if (np && nt) return { pass: parseInt(np[1]), total: parseInt(nt[1]) };
  // mocha
  const mp = output.match(/(\d+)\s+passing/);
  if (mp) { const p = parseInt(mp[1]); const mf = output.match(/(\d+)\s+failing/); return { pass: p, total: p + (mf ? parseInt(mf[1]) : 0) }; }
  // go test: "ok ... (0.5s)" per package, "FAIL" for failures, "--- PASS:" / "--- FAIL:" per test
  const goPasses = (output.match(/--- PASS:/g) || []).length;
  const goFails = (output.match(/--- FAIL:/g) || []).length;
  if (goPasses + goFails > 0) return { pass: goPasses, total: goPasses + goFails };
  // rust/cargo: "test result: ok. N passed; M failed"
  const rustMatch = output.match(/test result:.*?(\d+)\s+passed.*?(\d+)\s+failed/);
  if (rustMatch) return { pass: parseInt(rustMatch[1]), total: parseInt(rustMatch[1]) + parseInt(rustMatch[2]) };
  // pytest
  const pp = output.match(/(\d+)\s+passed/);
  if (pp) { const p = parseInt(pp[1]); const pf = output.match(/(\d+)\s+failed/); return { pass: p, total: p + (pf ? parseInt(pf[1]) : 0) }; }
  return { pass: 0, total: 0 };
}

function installDeps(dir, testCommand) {
  try {
    // Python
    if (fs.existsSync(path.join(dir, 'pyproject.toml')) || fs.existsSync(path.join(dir, 'setup.py'))) {
      // Create venv and install
      if (!fs.existsSync(path.join(dir, '.venv'))) {
        spawnSync('python3', ['-m', 'venv', '.venv'], { cwd: dir, stdio: 'pipe', timeout: 60000 });
      }
      const pip = path.join(dir, '.venv', 'bin', 'pip');
      if (fs.existsSync(path.join(dir, 'pyproject.toml'))) {
        spawnSync(pip, ['install', '-e', '.[dev,test]'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
      } else {
        spawnSync(pip, ['install', '-e', '.[test]'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
      }
      // Also install pytest if not already
      spawnSync(pip, ['install', 'pytest'], { cwd: dir, stdio: 'pipe', timeout: 60000 });
      return;
    }
    // Go — no install step needed (go test fetches deps automatically)
    if (fs.existsSync(path.join(dir, 'go.mod'))) return;
    // Rust — cargo handles deps automatically
    if (fs.existsSync(path.join(dir, 'Cargo.toml'))) return;
    // JavaScript
    if (fs.existsSync(path.join(dir, 'bun.lock')) || fs.existsSync(path.join(dir, 'bun.lockb')))
      spawnSync('bun', ['install'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
    else if (testCommand?.startsWith('pnpm') || fs.existsSync(path.join(dir, 'pnpm-lock.yaml')))
      spawnSync('pnpm', ['install', '--no-frozen-lockfile'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
    else if (fs.existsSync(path.join(dir, 'package.json')))
      spawnSync('npm', ['install'], { cwd: dir, stdio: 'pipe', timeout: 300000 });
  } catch {}
}

function runTests(dir, testCommand) {
  let cmd = testCommand;
  if (cmd === 'npm test' || cmd === 'pnpm test') {
    try {
      const pkg = JSON.parse(fs.readFileSync(path.join(dir, 'package.json'), 'utf8'));
      if (pkg.scripts?.unit) cmd = cmd.replace('test', 'run unit');
      else if (pkg.scripts?.['tests-only']) cmd = cmd.replace('test', 'run tests-only');
    } catch {}
  }
  // Python: use venv if available
  if (cmd.startsWith('python') && fs.existsSync(path.join(dir, '.venv', 'bin', 'python'))) {
    cmd = cmd.replace(/^python3?/, path.join(dir, '.venv', 'bin', 'python'));
  }
  const env = { ...process.env };
  // Go: ensure module mode
  if (cmd.startsWith('go test')) env.GO111MODULE = 'on';
  try { return execSync(cmd, { cwd: dir, stdio: 'pipe', timeout: 600000, encoding: 'utf8', env }); }
  catch (err) { return (err.stdout || '') + (err.stderr || ''); }
}

function copyTestFiles(srcDir, dstDir) {
  function walk(dir) {
    let entries;
    try { entries = fs.readdirSync(dir, { withFileTypes: true }); } catch { return; }
    for (const entry of entries) {
      const full = path.join(dir, entry.name);
      const rel = path.relative(srcDir, full);
      if (entry.isDirectory()) {
        if (entry.name === '.git' || entry.name === 'node_modules') continue;
        walk(full);
      } else if (entry.isFile()) {
        const p = rel.toLowerCase();
        if (p.includes('/test/') || p.includes('/tests/') || p.includes('/__tests__/') ||
            p.includes('.test.') || p.includes('.spec.') ||
            p.endsWith('_test.go') || p.endsWith('_test.py') || p.startsWith('test_') ||
            p.endsWith('_test.rs')) {
          const dst = path.join(dstDir, rel);
          try { fs.mkdirSync(path.dirname(dst), { recursive: true }); fs.copyFileSync(full, dst); } catch {}
        }
      }
    }
  }
  walk(srcDir);
}

function extractTestHunks(diff) {
  if (!diff) return null;
  const testPatterns = ['/test/', '/tests/', '/__tests__/', '.test.', '.spec.', '_test.', 'test_'];
  const testPrefixes = ['test/', 'tests/', '__tests__/'];
  const chunks = diff.split(/^(diff --git )/m);
  const kept = [];
  for (let i = 0; i < chunks.length; i++) {
    if (!chunks[i].startsWith('diff --git ')) continue;
    const chunk = chunks[i] + (chunks[i + 1] || '');
    i++;
    const fileMatch = chunk.match(/^diff --git a\/(\S+)/);
    if (!fileMatch) continue;
    const filePath = fileMatch[1].toLowerCase();
    const isTest = testPatterns.some(p => filePath.includes(p)) || testPrefixes.some(p => filePath.startsWith(p));
    if (isTest) kept.push(chunk);
  }
  return kept.length > 0 ? kept.join('') : null;
}

function computeBaseline(cacheDir, beforeCommit, afterCommit, testCommand, prDiff) {
  const tmpBefore = fs.mkdtempSync(path.join(os.tmpdir(), 'mine-buggy-'));
  const tmpAfter = fs.mkdtempSync(path.join(os.tmpdir(), 'mine-fix-'));
  try {
    // Before (buggy) + test hunks from fix diff injected
    spawnSync('cp', ['-r', cacheDir + '/', tmpBefore + '/'], { stdio: 'pipe' });
    spawnSync('git', ['checkout', '-f', beforeCommit], { cwd: tmpBefore, stdio: 'pipe' });
    spawnSync('git', ['clean', '-fd'], { cwd: tmpBefore, stdio: 'pipe' });
    installDeps(tmpBefore, testCommand);

    // Inject test hunks from the PR diff (not whole files — preserves existing tests)
    const testDiff = prDiff ? extractTestHunks(prDiff) : null;
    if (testDiff) {
      const patchFile = path.join(os.tmpdir(), `mine-testpatch-${Date.now()}.patch`);
      fs.writeFileSync(patchFile, testDiff);
      try {
        spawnSync('git', ['apply', '--whitespace=fix', patchFile], { cwd: tmpBefore, stdio: 'pipe' });
      } catch {
        try { spawnSync('git', ['apply', '--3way', patchFile], { cwd: tmpBefore, stdio: 'pipe' }); } catch {}
      }
      try { fs.unlinkSync(patchFile); } catch {}
    } else {
      // Fallback: copy whole test files from fix commit
      const tmpFixSrc = fs.mkdtempSync(path.join(os.tmpdir(), 'mine-fixsrc-'));
      try {
        spawnSync('cp', ['-r', path.join(cacheDir, '.git'), path.join(tmpFixSrc, '.git')], { stdio: 'pipe' });
        spawnSync('git', ['checkout', '-f', afterCommit], { cwd: tmpFixSrc, stdio: 'pipe' });
        copyTestFiles(tmpFixSrc, tmpBefore);
      } finally { try { fs.rmSync(tmpFixSrc, { recursive: true, force: true }); } catch {} }
    }
    const beforeResult = parseTestCounts(runTests(tmpBefore, testCommand));

    // After (fixed)
    spawnSync('cp', ['-r', cacheDir + '/', tmpAfter + '/'], { stdio: 'pipe' });
    spawnSync('git', ['checkout', '-f', afterCommit], { cwd: tmpAfter, stdio: 'pipe' });
    spawnSync('git', ['clean', '-fd'], { cwd: tmpAfter, stdio: 'pipe' });
    installDeps(tmpAfter, testCommand);
    const afterResult = parseTestCounts(runTests(tmpAfter, testCommand));

    return {
      baseline_passing: beforeResult.pass, fix_passing: afterResult.pass,
      broken_by_bug: afterResult.pass - beforeResult.pass,
    };
  } finally {
    try { fs.rmSync(tmpBefore, { recursive: true, force: true }); } catch {}
    try { fs.rmSync(tmpAfter, { recursive: true, force: true }); } catch {}
    try { fs.rmSync(tmpFixSrc, { recursive: true, force: true }); } catch {}
  }
}

function fetchPRDiff(repo, prNumber) {
  const res = run('gh', ['pr', 'diff', String(prNumber), '--repo', repo], { allowFail: true });
  return res.status === 0 ? res.stdout : null;
}

function mineRepo(repo) {
  const [owner, name] = repo.split('/');
  process.stdout.write(`\n[${repo}] searching fix PRs... `);

  let prs;
  try { prs = searchFixPRs(repo); }
  catch (e) { console.error(`FAILED: ${e.message}`); return 0; }
  console.log(`${prs.length} candidates`);

  if (!prs.length) return 0;

  const testCommand = detectTestCommand(repo);
  if (!testCommand) { console.log(`  SKIP — no test command`); return 0; }

  const cacheDir = ensureRepoCache(repo);
  if (!cacheDir) { console.log(`  SKIP — clone failed`); return 0; }

  let saved = 0;
  for (const pr of prs) {
    const id = `${name}-pr${pr.number}`;
    const outPath = path.join(CHALLENGES_DIR, `${id}.json`);
    if (fs.existsSync(outPath)) continue;

    // Skip squash-merged PRs (no merge commit metadata)
    if (!pr.mergeCommit || !pr.mergeCommit.oid) {
      console.log(`    SKIP — no merge commit metadata for #${pr.number} (likely squash merge)`);
      continue;
    }

    // Get parent commit
    const commitRes = run('gh', ['api', `repos/${owner}/${name}/commits/${pr.mergeCommit.oid}`, '--jq', '.parents[0].sha'], { allowFail: true });
    if (commitRes.status !== 0 || !commitRes.stdout.trim()) continue;
    const beforeCommit = commitRes.stdout.trim();

    console.log(`  ${id}: "${(pr.title||'').slice(0,60)}" — computing baseline...`);
    try {
      // Fetch PR diff FIRST so we can use diff-based test injection
      const diff = fetchPRDiff(repo, pr.number);
      const bl = computeBaseline(cacheDir, beforeCommit, pr.mergeCommit.oid, testCommand, diff);
      if (bl.broken_by_bug < MIN_BROKEN) {
        console.log(`    SKIP — broken_by_bug=${bl.broken_by_bug}`);
        continue;
      }
      // Sanity check: baseline shouldn't be wildly different from fix
      if (bl.baseline_passing > 0 && bl.fix_passing > bl.baseline_passing * 2) {
        console.log(`    SKIP — suspicious baseline (${bl.baseline_passing} → ${bl.fix_passing})`);
        continue;
      }
      const challenge = {
        id, repo, repoUrl: `https://github.com/${repo}`,
        issue: { number: pr.number, title: pr.title, body: '' },
        pr: { number: pr.number, url: `https://github.com/${repo}/pull/${pr.number}` },
        buggyCommit: beforeCommit, fixCommit: pr.mergeCommit.oid,
        fixDiff: diff || '', testCommand,
        baseline_passing: bl.baseline_passing, fix_passing: bl.fix_passing,
        broken_by_bug: bl.broken_by_bug,
        difficulty: { filesChanged: pr.changedFiles, linesAdded: pr.additions, linesRemoved: pr.deletions },
        minedAt: new Date().toISOString(),
      };
      fs.writeFileSync(outPath, JSON.stringify(challenge, null, 2));
      saved++;
      console.log(`    ✓ saved ${id} (broken=${bl.broken_by_bug}, +${pr.additions}/-${pr.deletions})`);
    } catch (e) {
      console.log(`    ERROR: ${(e.message || '').slice(0, 80)}`);
    }
  }
  return saved;
}

console.log('AgentElo PR-Based Challenge Miner');
console.log(`Repos: ${ACTIVE_REPOS.length}, Min broken: ${MIN_BROKEN}`);
let total = 0;
for (const repo of ACTIVE_REPOS) { total += mineRepo(repo); }
console.log(`\nDone. ${total} challenges saved.`);
