+
+test('diagnostics channel reports error status code for sync handler with setErrorHandler', (t, done) => {
+  t.plan(3)
+  const fastify = Fastify()
+  t.after(() => fastify.close())
+
+  fastify.setErrorHandler((error, request, reply) => {
+    reply.status(500).send({ ok: false })
+  })
+
+  fastify.register((app, options, next) => {
+    app.setErrorHandler((error, request, reply) => {
+      throw error
+    })
+
+    app.get('/good', async (request, reply) => {
+      throw new Error('bar')
+    })
+
+    next()
+  })
+
+  let diagnosticsStatusCode
+  diagnostics.subscribe('tracing:fastify.request.handler:error', ({ reply }) => {
+    diagnosticsStatusCode = reply.statusCode
+  })
+
+  fastify.inject({
+    method: 'GET',
+    url: '/good'
+  }, (error, res) => {
+    t.assert.ifError(error)
+    t.assert.strictEqual(diagnosticsStatusCode, 500)
+    t.assert.strictEqual(res.statusCode, 500)
+    done()
+  })
+})
+
+test('diagnostics channel reports error status code for async handler', async t => {
+  t.plan(2)
+  const fastify = Fastify()
+  t.after(() => fastify.close())
+
+  let diagnosticsStatusCode
+  diagnostics.subscribe('tracing:fastify.request.handler:error', ({ reply }) => {
+    diagnosticsStatusCode = reply.statusCode
+  })
+
+  fastify.get('/', async () => {
+    throw new Error('async error')
+  })
+
+  await fastify.inject({ method: 'GET', url: '/' })
+  t.assert.strictEqual(diagnosticsStatusCode, 500)
+  t.assert.strictEqual(diagnosticsStatusCode, 500)
+})
+
+test('diagnostics channel reports custom error status code from error instance', async t => {
+  t.plan(2)
+  const fastify = Fastify()
+  t.after(() => fastify.close())
+
+  let diagnosticsStatusCode
+  diagnostics.subscribe('tracing:fastify.request.handler:error', ({ reply }) => {
+    diagnosticsStatusCode = reply.statusCode
+  })
+
+  fastify.get('/', async () => {
+    const err = new Error('custom status')
+    err.statusCode = 418
+    throw err
+  })
+
+  await fastify.inject({ method: 'GET', url: '/' })
+  t.assert.strictEqual(diagnosticsStatusCode, 418)
+  t.assert.strictEqual(diagnosticsStatusCode, 418)
+})
+
+test('diagnostics channel reports status code set via reply.status before throw', async t => {
+  t.plan(2)
+  const fastify = Fastify()
+  t.after(() => fastify.close())
+
+  let diagnosticsStatusCode
+  diagnostics.subscribe('tracing:fastify.request.handler:error', ({ reply }) => {
+    diagnosticsStatusCode = reply.statusCode
+  })
+
+  fastify.get('/', async (request, reply) => {
+    reply.status(503)
+    throw new Error('service unavailable')
+  })
+
+  await fastify.inject({ method: 'GET', url: '/' })
+  t.assert.strictEqual(diagnosticsStatusCode, 503)
+  t.assert.strictEqual(diagnosticsStatusCode, 503)
+})

